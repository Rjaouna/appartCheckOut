{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}
{% block body_class %}public-body{% endblock %}

{% block body %}
    <section class="public-landing-shell">
        <section class="public-landing-card public-landing-card-narrow public-landing-card-tenant-home">
            <span class="eyebrow">Bienvenue</span>
            <h1>Accéder à mon appartement</h1>
            <p class="muted">Saisissez le code reçu pour retrouver vos informations d’accès, vos consignes et les contacts utiles.</p>

            {% if errorMessage %}
                <div class="alert error">{{ errorMessage }}</div>
            {% endif %}

            <form method="post" class="stack-form public-tenant-home-form">
                <input type="hidden" name="_token" value="{{ csrf_token('tenant_lookup') }}">
                <label>
                    <span>Code d’accès</span>
                    <input type="text" name="accessCode" value="{{ submittedCode }}" placeholder="Exemple : A124B" required autofocus {{ isTenantLookupBlocked ? 'disabled' : '' }}>
                </label>
                <button class="primary-button" type="submit" {{ isTenantLookupBlocked ? 'disabled' : '' }}>
                    {{ isTenantLookupBlocked ? 'Réessayer plus tard' : 'Accéder à mon appartement' }}
                </button>
            </form>

            {% if isTenantLookupBlocked %}
                <p class="muted">Ce blocage temporaire concerne cet appareil, pas le logement.</p>
            {% endif %}

            <div class="public-employee-access">
                <button
                    class="public-employee-access-link"
                    type="button"
                    data-employee-entry-trigger
                    aria-controls="employeeEntryModal"
                    aria-haspopup="dialog"
                >
                    Connexion employé / administration
                </button>
            </div>
        </section>
    </section>

    <div class="modal fade" id="employeeEntryModal" tabindex="-1" aria-labelledby="employeeEntryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content employee-entry-modal-content">
                <div class="modal-header employee-entry-modal-header">
                    <div>
                        <span class="eyebrow">Accès équipe</span>
                        <h4 class="modal-title" id="employeeEntryModalLabel">Saisir le code d’accès</h4>
                    </div>
                    <button type="button" class="btn-close" aria-label="Fermer" data-modal-close></button>
                </div>

                <form
                    method="post"
                    action="{{ path('employee_entry_verify') }}"
                    class="employee-entry-form"
                    data-async-form
                    data-employee-entry-form
                >
                    <div class="employee-entry-display" aria-live="polite">
                        <span class="employee-entry-display-label">Code</span>
                        <div class="employee-entry-dots" data-employee-entry-dots>
                            <span class="employee-entry-dot"></span>
                            <span class="employee-entry-dot"></span>
                            <span class="employee-entry-dot"></span>
                            <span class="employee-entry-dot"></span>
                        </div>
                    </div>

                    <input
                        type="password"
                        name="entryCode"
                        value=""
                        inputmode="numeric"
                        pattern="[0-9]*"
                        maxlength="6"
                        autocomplete="one-time-code"
                        class="employee-entry-input"
                        data-employee-entry-input
                        aria-label="Code d’accès équipe"
                        readonly
                    >

                    <div class="employee-entry-keypad" aria-label="Clavier numérique">
                        {% for digit in ['1', '2', '3', '4', '5', '6', '7', '8', '9'] %}
                            <button type="button" class="employee-entry-key" data-employee-entry-digit="{{ digit }}">{{ digit }}</button>
                        {% endfor %}
                        <button type="button" class="employee-entry-key employee-entry-key-muted" data-employee-entry-clear>Effacer</button>
                        <button type="button" class="employee-entry-key" data-employee-entry-digit="0">0</button>
                        <button type="button" class="employee-entry-key employee-entry-key-muted" data-employee-entry-backspace>Suppr.</button>
                    </div>

                    <button class="primary-button employee-entry-submit" type="submit">Continuer</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
