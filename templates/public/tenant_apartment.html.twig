{% extends 'base.html.twig' %}

{% block title %}Mon appartement{% endblock %}
{% block body_class %}public-body{% endblock %}

{% block body %}
    {% set leadEmployee = assignedEmployees|first %}
    {% set extraEmployees = assignedEmployees|length > 1 ? assignedEmployees|slice(1) : [] %}
    {% set hasGuidebook = apartment.hasGuestGuideContent %}
    {% set exitTenantUrl = path('tenant_lookup_exit') %}

    <section class="tenant-app-shell">
        <article class="tenant-app-hero">
            <div class="tenant-app-hero-bar">
                <div class="tenant-app-hero-copy">
                    <span class="eyebrow">Bienvenue</span>
                    <h1>{{ apartment.name }}</h1>
                    <p>{{ apartment.fullAddress }}</p>
                </div>

                <button
                    class="tenant-burger-button"
                    type="button"
                    aria-label="Ouvrir le menu locataire"
                    title="Ouvrir le menu"
                    data-action-menu-trigger
                    data-action-menu-title="Menu locataire"
                    data-action-menu-source="#tenant-main-menu-source"
                >
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                    </svg>
                </button>
            </div>

        </article>

        <section class="tenant-feature-grid">
            <button class="tenant-feature-card" type="button" data-panel-open="#tenant-panel-access" data-panel-group="tenant-public">
                <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'home' } only %}</span>
                <div class="tenant-feature-copy">
                    <strong>Infos appartement</strong>
                    <span>Adresse, codes et consignes d'entree.</span>
                </div>
            </button>

            {% if hasGuidebook %}
                <button class="tenant-feature-card" type="button" data-panel-open="#tenant-panel-guidebook" data-panel-group="tenant-public">
                    <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'guidebook' } only %}</span>
                    <div class="tenant-feature-copy">
                        <strong>Livret d'accueil</strong>
                        <span>Regles, depart, urgences et infos utiles.</span>
                    </div>
                </button>
            {% endif %}

            {% if manuals is not empty %}
                <button class="tenant-feature-card" type="button" data-panel-open="#tenant-panel-manuals" data-panel-group="tenant-public">
                    <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'manuals' } only %}</span>
                    <div class="tenant-feature-copy">
                        <strong>Manuels</strong>
                        <span>Videos d'utilisation des equipements.</span>
                    </div>
                </button>
            {% endif %}
        </section>

        <p class="tenant-home-helper">Toutes les informations utiles sont rangees par rubrique. Utilisez le menu pour retrouver le Wi-Fi, les services, le contact ou les consignes importantes.</p>
        <a class="tenant-exit-link tenant-home-exit-link" href="{{ exitTenantUrl }}">Quitter l'espace locataire</a>

        <div id="tenant-main-menu-source" class="workflow-actions-source" hidden>
            <div class="tenant-menu-grid">
                {% if apartment.guestWifiName or apartment.guestWifiPassword or apartment.guestWifiInstructions %}
                    <button class="tenant-icon-tile" type="button" data-panel-open="#tenant-panel-wifi" data-panel-group="tenant-public">
                        <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'wifi' } only %}</span>
                        <span class="tenant-icon-label">Wi-Fi</span>
                    </button>
                {% endif %}

                <button class="tenant-icon-tile" type="button" data-panel-open="#tenant-panel-share" data-panel-group="tenant-public">
                    <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'share' } only %}</span>
                    <span class="tenant-icon-label">Envoyer l'adresse</span>
                </button>

                {% if serviceContactEmployee and serviceExtras is not empty %}
                    <button class="tenant-icon-tile" type="button" data-panel-open="#tenant-panel-services" data-panel-group="tenant-public">
                        <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'services' } only %}</span>
                        <span class="tenant-icon-label">Services</span>
                    </button>
                {% endif %}

                <button class="tenant-icon-tile" type="button" data-panel-open="#tenant-panel-contact" data-panel-group="tenant-public">
                    <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'contact' } only %}</span>
                    <span class="tenant-icon-label">Contact</span>
                </button>

                <button class="tenant-icon-tile" type="button" data-panel-open="#tenant-panel-important" data-panel-group="tenant-public">
                    <span class="tenant-icon-mark">{% include 'public/_tenant_icon.html.twig' with { icon: 'important' } only %}</span>
                    <span class="tenant-icon-label">Important</span>
                </button>
            </div>
        </div>

        <div id="tenant-panel-backdrop" class="tenant-panel-backdrop is-collapsed" data-panel-close-group="tenant-public" aria-hidden="true"></div>

        <section id="tenant-panel-access" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
            <div class="tenant-panel-topbar">
                <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-access" aria-label="Retour a l'accueil locataire">Accueil</button>
                <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                    </svg>
                </button>
            </div>
            <div class="tenant-panel-scroll">
                <div class="tenant-panel-head">
                    <span class="tenant-panel-kicker">Essentiel</span>
                    <h2>Infos appartement</h2>
                    <p>Adresse, navigation, codes et consignes d'entree sont regroupes ici pour vous installer sans chercher.</p>
                </div>

                <div class="tenant-action-stack">
                    {% if apartment.wazeLink %}
                        <a
                            class="tenant-waze-button full-width"
                            href="{{ apartment.wazeLink }}"
                            target="_blank"
                            rel="noreferrer"
                            data-external-confirm
                            data-confirm-title="Ouvrir Waze"
                            data-confirm-message="Vous allez quitter votre espace pour ouvrir l'adresse dans Waze. Voulez-vous continuer ?"
                        >
                            <span class="tenant-waze-icon">{% include 'public/_tenant_icon.html.twig' with { icon: 'waze' } only %}</span>
                            <span>Ouvrir l'itineraire Waze</span>
                        </a>
                    {% endif %}
                    {% if apartment.orderedAccessSteps is not empty %}
                        <button class="secondary-button full-width" type="button" data-panel-open="#tenant-panel-apartment-access" data-panel-group="tenant-public">
                            Voir les etapes d'acces
                        </button>
                    {% endif %}
                </div>

                <div class="tenant-panel-card-grid">
                    <article class="tenant-info-card tenant-info-card-wide">
                        <span class="editable-field-label">Adresse</span>
                        <strong>{{ apartment.fullAddress }}</strong>
                    </article>
                    <article class="tenant-info-card">
                        <span class="editable-field-label">Code immeuble</span>
                        <strong>{{ apartment.buildingAccessCode ?: '-' }}</strong>
                    </article>
                    <article class="tenant-info-card">
                        <span class="editable-field-label">Code boite a cles / porte</span>
                        <strong>{{ apartment.keyBoxCode ?: '-' }}</strong>
                    </article>
                    <article class="tenant-info-card">
                        <span class="editable-field-label">Boite aux lettres</span>
                        <strong>{{ apartment.mailboxNumber ?: '-' }}</strong>
                    </article>
                    <article class="tenant-info-card tenant-info-card-wide">
                        <span class="editable-field-label">Consignes d'entree</span>
                        <div class="formatted-rich-text">
                            {% if apartment.entryInstructions %}
                                {{ apartment.entryInstructions|raw }}
                            {% else %}
                                <p>Aucune consigne pour le moment.</p>
                            {% endif %}
                        </div>
                    </article>
                </div>
            </div>
        </section>

        {% if apartment.orderedAccessSteps is not empty %}
            <section id="tenant-panel-apartment-access" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
                <div class="tenant-panel-topbar">
                    <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-apartment-access" aria-label="Retour a l'accueil locataire">Accueil</button>
                    <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                <div class="tenant-panel-scroll">
                    <div class="tenant-panel-head">
                        <span class="tenant-panel-kicker">Arrivee</span>
                        <h2>Acces a l'appartement</h2>
                        <p>Suivez les etapes dans l'ordre. Les photos vous aident a vous reperer rapidement sur place.</p>
                    </div>

                    <div class="tenant-step-list">
                        {% for step in apartment.orderedAccessSteps %}
                            <article class="tenant-step-card">
                                <div class="tenant-step-copy">
                                    <span class="eyebrow">Etape {{ loop.index }}</span>
                                    <div class="formatted-rich-text"><p>{{ step.instruction }}</p></div>
                                </div>
                                {% if step.imagePath %}
                                    <img src="{{ step.imagePath }}" alt="Etape {{ loop.index }}">
                                {% endif %}
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}

        {% if apartment.guestWifiName or apartment.guestWifiPassword or apartment.guestWifiInstructions %}
            <section id="tenant-panel-wifi" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
                <div class="tenant-panel-topbar">
                    <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-wifi" aria-label="Retour a l'accueil locataire">Accueil</button>
                    <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                <div class="tenant-panel-scroll">
                    <div class="tenant-panel-head">
                        <span class="tenant-panel-kicker">Connexion</span>
                        <h2>Connexion Wi-Fi</h2>
                        <p>Retrouvez le nom du reseau, le mot de passe et les precisions utiles pour vous connecter.</p>
                    </div>

                    <div class="tenant-panel-card-grid">
                        {% if apartment.guestWifiName %}
                            <article class="tenant-info-card">
                                <span class="editable-field-label">Reseau</span>
                                <strong>{{ apartment.guestWifiName }}</strong>
                            </article>
                        {% endif %}
                        {% if apartment.guestWifiPassword %}
                            <article class="tenant-info-card">
                                <span class="editable-field-label">Mot de passe</span>
                                <strong>{{ apartment.guestWifiPassword }}</strong>
                            </article>
                        {% endif %}
                        {% if apartment.guestWifiInstructions %}
                            <article class="tenant-info-card tenant-info-card-wide">
                                <span class="editable-field-label">Precision</span>
                                <div class="formatted-rich-text">{{ apartment.guestWifiInstructions|raw }}</div>
                            </article>
                        {% endif %}
                    </div>
                </div>
            </section>
        {% endif %}

        <section id="tenant-panel-share" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
            <div class="tenant-panel-topbar">
                <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-share" aria-label="Retour a l'accueil locataire">Accueil</button>
                <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                    </svg>
                </button>
            </div>
            <div class="tenant-panel-scroll">
                <div class="tenant-panel-head">
                    <span class="tenant-panel-kicker">Partager</span>
                    <h2>Adresse et navigation</h2>
                    <p>Envoyez l'adresse a un proche ou ouvrez une application de navigation en un clic.</p>
                </div>

                <article class="tenant-info-card tenant-info-card-wide tenant-address-card">
                    <span class="editable-field-label">Adresse du logement</span>
                    <strong>{{ apartment.fullAddress }}</strong>
                </article>

                <div class="tenant-action-stack">
                    <a class="primary-button full-width" href="{{ whatsAppShareUrl }}" target="_blank" rel="noreferrer">Partager l'adresse sur WhatsApp</a>
                    {% if apartment.googleMapsLink %}
                        <a class="secondary-button full-width" href="{{ apartment.googleMapsLink }}" target="_blank" rel="noreferrer">Ouvrir Google Maps</a>
                    {% endif %}
                    {% if apartment.wazeLink %}
                        <a
                            class="secondary-button full-width"
                            href="{{ apartment.wazeLink }}"
                            target="_blank"
                            rel="noreferrer"
                            data-external-confirm
                            data-confirm-title="Ouvrir Waze"
                            data-confirm-message="Vous allez quitter votre espace pour ouvrir l'adresse dans Waze. Voulez-vous continuer ?"
                        >Ouvrir Waze</a>
                    {% endif %}
                </div>
            </div>
        </section>

        {% if hasGuidebook %}
            <section id="tenant-panel-guidebook" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
                <div class="tenant-panel-topbar">
                    <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-guidebook" aria-label="Retour a l'accueil locataire">Accueil</button>
                    <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                <div class="tenant-panel-scroll">
                    <div class="tenant-panel-head">
                        <span class="tenant-panel-kicker">Sejour</span>
                        <h2>Livret d'accueil</h2>
                        <p>Regles du logement, depart, urgences et equipements: les informations utiles de votre sejour.</p>
                    </div>

                    <div class="tenant-guidebook-grid">
                        {% if apartment.guestHouseRules %}
                            <article class="tenant-info-card">
                                <h3>Regles du logement</h3>
                                <div class="formatted-rich-text">{{ apartment.guestHouseRules|raw }}</div>
                            </article>
                        {% endif %}
                        {% if apartment.guestDepartureInstructions %}
                            <article class="tenant-info-card">
                                <h3>Depart</h3>
                                <div class="formatted-rich-text">{{ apartment.guestDepartureInstructions|raw }}</div>
                            </article>
                        {% endif %}
                        {% if apartment.guestEmergencyInfo %}
                            <article class="tenant-info-card">
                                <h3>Urgences</h3>
                                <div class="formatted-rich-text">{{ apartment.guestEmergencyInfo|raw }}</div>
                            </article>
                        {% endif %}
                        {% if apartment.guestEquipmentInfo %}
                            <article class="tenant-info-card">
                                <h3>Equipements utiles</h3>
                                <div class="formatted-rich-text">{{ apartment.guestEquipmentInfo|raw }}</div>
                            </article>
                        {% endif %}
                    </div>

                    <a class="tenant-exit-link tenant-exit-link-bottom" href="{{ exitTenantUrl }}">Quitter l'espace locataire</a>
                </div>
            </section>
        {% endif %}

        {% if serviceContactEmployee and serviceExtras is not empty %}
            <section id="tenant-panel-services" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
                <div class="tenant-panel-topbar">
                    <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-services" aria-label="Retour a l'accueil locataire">Accueil</button>
                    <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                <div class="tenant-panel-scroll">
                    <div class="tenant-panel-head">
                        <span class="tenant-panel-kicker">Extras</span>
                        <h2>Services disponibles</h2>
                        <p>Besoin d'un coup de main pendant votre sejour ? Choisissez un service et envoyez votre demande directement sur WhatsApp.</p>
                    </div>

                    <article class="tenant-service-hero">
                        <span class="tenant-service-hero-icon">{% include 'public/_tenant_icon.html.twig' with { icon: 'services' } only %}</span>
                        <div>
                            <strong>{{ serviceContactEmployee.fullName }}</strong>
                            <p>Votre contact peut vous aider a organiser un service simple et rapide.</p>
                        </div>
                    </article>

                    <div class="tenant-service-grid">
                        {% for service in serviceExtras %}
                            <a class="tenant-service-card" href="{{ service.whatsAppUrl }}" target="_blank" rel="noreferrer" title="{{ service.title }}">
                                <span class="tenant-service-icon">{% include 'public/_tenant_icon.html.twig' with { icon: 'services' } only %}</span>
                                <span class="tenant-service-copy">
                                    <strong>{{ service.label }}</strong>
                                    <span>Faire une demande a {{ serviceContactEmployee.fullName }}</span>
                                </span>
                                <span class="tenant-service-whatsapp">
                                    {% include 'public/_tenant_icon.html.twig' with { icon: 'whatsapp' } only %}
                                    WhatsApp
                                </span>
                                <span class="tenant-service-arrow" aria-hidden="true">&rarr;</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}

        {% if manuals is not empty %}
            <section id="tenant-panel-manuals" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
                <div class="tenant-panel-topbar">
                    <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-manuals" aria-label="Retour a l'accueil locataire">Accueil</button>
                    <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
                <div class="tenant-panel-scroll">
                    <div class="tenant-panel-head">
                        <span class="tenant-panel-kicker">Aide video</span>
                        <h2>Manuels d'utilisation</h2>
                        <p>Visionnez les explications courtes pour utiliser les equipements du logement sans hesitation.</p>
                    </div>

                    <div class="tenant-manual-grid">
                        {% for manual in manuals %}
                            <article class="tenant-manual-card">
                                <div class="tenant-manual-video-shell">
                                    <video controls preload="metadata" class="tenant-manual-video">
                                        <source src="{{ manual.videoPath }}">
                                        Votre navigateur ne peut pas lire cette video.
                                    </video>
                                </div>
                                <div class="tenant-manual-copy">
                                    <span class="public-tenant-badge">{{ manual.equipmentLabel }}</span>
                                    <h3>{{ manual.title }}</h3>
                                    {% if manual.shortMessage %}
                                        <p>{{ manual.shortMessage }}</p>
                                    {% endif %}
                                    {% if manual.importantNotice %}
                                        <div class="detail-note-soft tenant-manual-warning">
                                            <strong>Consigne importante</strong>
                                            <p>{{ manual.importantNotice }}</p>
                                        </div>
                                    {% endif %}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}

        <section id="tenant-panel-contact" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
            <div class="tenant-panel-topbar">
                <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-contact" aria-label="Retour a l'accueil locataire">Accueil</button>
                <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                    </svg>
                </button>
            </div>
            <div class="tenant-panel-scroll">
                <div class="tenant-panel-head">
                    <span class="tenant-panel-kicker">Besoin d'aide ?</span>
                    <h2>Votre contact</h2>
                    <p>Pour une question urgente ou une demande pendant le sejour, contactez la personne en charge du logement.</p>
                </div>

                {% if leadEmployee %}
                    <div class="tenant-contact-grid">
                        <article class="tenant-contact-card">
                            <div class="admin-user-avatar public-contact-avatar {{ leadEmployee.photoPath ? 'has-photo' : '' }}">
                                {% if leadEmployee.photoPath %}
                                    <img src="{{ leadEmployee.photoPath }}" alt="{{ leadEmployee.fullName }}">
                                {% else %}
                                    <span>{{ leadEmployee.fullName|slice(0, 1)|upper }}</span>
                                {% endif %}
                            </div>
                            <div class="tenant-contact-copy">
                                <strong>{{ leadEmployee.fullName }}</strong>
                                {% if leadEmployee.phoneNumber %}
                                    <a class="inline-detail-link admin-user-phone-link" href="tel:{{ leadEmployee.phoneNumber }}">{{ leadEmployee.phoneNumber }}</a>
                                {% else %}
                                    <span class="muted">Numero non renseigne</span>
                                {% endif %}
                            </div>
                        </article>

                        {% for employee in extraEmployees %}
                            <article class="tenant-contact-card tenant-contact-card-soft">
                                <strong>{{ employee.fullName }}</strong>
                                {% if employee.phoneNumber %}
                                    <a class="inline-detail-link admin-user-phone-link" href="tel:{{ employee.phoneNumber }}">{{ employee.phoneNumber }}</a>
                                {% else %}
                                    <span class="muted">Numero non renseigne</span>
                                {% endif %}
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="empty-state">Aucun employe actif n'est encore assigne a cet appartement.</p>
                {% endif %}
            </div>
        </section>

        <section id="tenant-panel-important" class="tenant-icon-panel is-collapsed" data-panel-name data-panel-group="tenant-public">
            <div class="tenant-panel-topbar">
                <button class="tenant-panel-back-button" type="button" data-panel-close="#tenant-panel-important" aria-label="Retour a l'accueil locataire">Accueil</button>
                <button class="tenant-burger-button tenant-panel-menu-button" type="button" aria-label="Ouvrir le menu locataire" title="Ouvrir le menu" data-action-menu-trigger data-action-menu-title="Menu locataire" data-action-menu-source="#tenant-main-menu-source">
                    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                        <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                    </svg>
                </button>
            </div>
            <div class="tenant-panel-scroll">
                <div class="tenant-panel-head">
                    <span class="tenant-panel-kicker">Important</span>
                    <h2>Informations importantes</h2>
                    <p>Quelques rappels importants pour proteger l'acces au logement et contacter rapidement l'equipe si besoin.</p>
                </div>

                <article class="tenant-warning-card">
                    <h3>Codes confidentiels</h3>
                    <p>Ne communiquez jamais ces codes a une autre personne. Si vous pensez qu'ils ont ete partages par erreur, contactez immediatement l'equipe du logement.</p>
                </article>
            </div>
        </section>
    </section>
{% endblock %}
