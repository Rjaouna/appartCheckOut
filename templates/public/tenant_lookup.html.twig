{% extends 'base.html.twig' %}

{% block title %}Acces locataire{% endblock %}
{% block body_class %}public-body{% endblock %}

{% block body %}
    <section class="public-landing-shell">
        <div class="auth-brand">
            <span class="top-app-brand-mark" aria-hidden="true">
                <svg viewBox="0 0 64 64">
                    <path fill="currentColor" d="M32 8c-3.8 0-6.6 1.9-8.3 5.7L13 38.2c-1.4 3.1-1.2 6 .6 8.6 1.8 2.6 4.4 3.9 7.8 3.9h21.2c3.4 0 6-1.3 7.8-3.9 1.8-2.6 2-5.5.6-8.6L40.3 13.7C38.6 9.9 35.8 8 32 8Zm0 7.3c1.1 0 1.9.6 2.5 1.9l10.8 24.7c.6 1.3.5 2.4-.2 3.4-.7 1-1.7 1.5-3 1.5H21.9c-1.3 0-2.3-.5-3-1.5-.7-1-.8-2.1-.2-3.4l10.8-24.7c.6-1.3 1.4-1.9 2.5-1.9Z"/>
                </svg>
            </span>
            <span class="top-app-brand-text">Check-out</span>
        </div>

        <section class="public-landing-card public-landing-card-narrow">
            <div class="auth-card-actions">
                <a class="secondary-button" href="{{ path('app_home') }}">Retour a l accueil</a>
                <a class="secondary-button" href="{{ path('app_login') }}">Je suis employe</a>
            </div>

            <span class="eyebrow">Acces locataire</span>
            <p class="muted">Saisissez le code de la boite a cles ou le code porte transmis pour votre arrivee.</p>

            {% if errorMessage %}
                <div class="alert error">{{ errorMessage }}</div>
            {% endif %}

            <form method="post" class="stack-form">
                <label>
                    <span>Code d acces</span>
                    <input type="text" name="accessCode" value="{{ submittedCode }}" placeholder="Exemple : A124B" required autofocus>
                </label>
                <button class="primary-button" type="submit">Valider</button>
            </form>
        </section>
    </section>
{% endblock %}
