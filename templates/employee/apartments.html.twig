{% extends 'base.html.twig' %}

{% block title %}Mes appartements{% endblock %}

{% block body %}
    <section class="page-head employee-page-head">
        <div>
            <h1>Mes appartements</h1>
        </div>
        <div class="head-actions">
            <a class="primary-button full-width" href="{{ path('employee_dashboard') }}">Retour</a>
        </div>
    </section>

    <section class="employee-apartments-grid">
        {% for apartment in apartments %}
            {% set activeManagers = apartment.assignedEmployees|filter(employee => 'ROLE_ADMIN' not in employee.roles) %}
            {% set managerListId = 'employee-apartment-managers-' ~ apartment.id %}
            {% set accessCode = apartment.buildingAccessCode ?: apartment.keyBoxCode ?: 'Non renseigné' %}
            <article class="employee-card employee-apartment-card" data-click-url="{{ path('employee_apartment_show', {id: apartment.id}) }}">
                <div class="employee-apartment-head">
                    <h2 class="employee-apartment-card-title">{{ apartment.name }}</h2>
                </div>
                <div class="apartment-card-info-stack">
                    <a class="address-link apartment-card-address-link" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">{{ apartment.fullAddress }}</a>
                    <dl class="key-values apartment-card-meta-grid">
                        <div>
                            <dt>Code d’accès</dt>
                            <dd>{{ accessCode }}</dd>
                        </div>
                        <div>
                            <dt>Gérants</dt>
                            <dd>
                                <button
                                    class="apartment-manager-toggle"
                                    type="button"
                                    data-toggle-target="#{{ managerListId }}"
                                    data-toggle-label-open="{{ activeManagers|length }}"
                                    data-toggle-label-closed="{{ activeManagers|length }}"
                                >
                                    {{ activeManagers|length }}
                                </button>
                            </dd>
                        </div>
                    </dl>
                    <div id="{{ managerListId }}" class="apartment-manager-list is-collapsed">
                        {% for employee in activeManagers %}
                            <span class="apartment-manager-link">{{ employee.fullName }}</span>
                        {% else %}
                            <span class="muted">Aucun employé assigné</span>
                        {% endfor %}
                    </div>
                </div>
            </article>
        {% else %}
            <p class="empty-state">Aucun appartement assigné pour le moment.</p>
        {% endfor %}
    </section>
{% endblock %}
