<div id="employee-dashboard-content" data-checkout-count="{{ checkoutCount }}">
    <section class="employee-home-intro">
        <h1>Mon espace</h1>
        <p>{{ user.fullName }}</p>
    </section>

    <section class="employee-home-stack">
        <article class="employee-home-primary-card {{ todayCheckout ? '' : 'is-empty' }}">
            <div class="employee-home-primary-icon" aria-hidden="true">
                <svg viewBox="0 0 64 64">
                    <path d="M19 17h26a6 6 0 0 1 6 6v18a6 6 0 0 1-6 6H19a6 6 0 0 1-6-6V23a6 6 0 0 1 6-6Zm0 8v16h26V25H19Zm5 4h16v4H24v-4Z" fill="currentColor"/>
                </svg>
            </div>
            <div class="employee-home-primary-content">
                {% if todayCheckout %}
                    <span class="employee-home-kicker">Check-out du jour prêt</span>
                    <h2>{{ todayCheckout.apartment.name }}</h2>
                    <p>
                        {% if todayCheckout.scheduledAt %}
                            Aujourd’hui à {{ todayCheckoutTimeLabel }}
                        {% else %}
                            Disponible dès maintenant
                        {% endif %}
                    </p>
                {% else %}
                    <span class="employee-home-kicker">Aucun check-out aujourd'hui</span>
                    <h2>Journée calme</h2>
                    <p>Le prochain check-out apparaîtra ici automatiquement dès qu'il sera programmé.</p>
                {% endif %}
            </div>
            {% if todayCheckout %}
                <a class="employee-home-primary-cta" href="{{ path('employee_checkout_show', {id: todayCheckout.id}) }}">
                    <span>Consulter</span>
                    <span class="employee-home-primary-arrow" aria-hidden="true">›</span>
                </a>
            {% else %}
                <span class="employee-home-primary-cta is-disabled">
                    <span>En attente</span>
                </span>
            {% endif %}

            <div class="employee-home-quick-links">
                <a class="employee-home-quick-link" href="{{ path('employee_calendar') }}">
                    <span class="employee-home-quick-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm11 8H6v10h12V10ZM6 8h12V6H6v2Z" fill="currentColor"/></svg>
                    </span>
                    <span>Calendrier</span>
                </a>
                <a class="employee-home-quick-link" href="{{ path('employee_history') }}">
                    <span class="employee-home-quick-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 1 0 8.95 10H19.9A7 7 0 1 1 13 5v3l5-4-5-4v3Zm-1 5h2v6h-5v-2h3V8Z" fill="currentColor"/></svg>
                    </span>
                    <span>Historique</span>
                </a>
            </div>
        </article>

        <div class="employee-home-card-grid employee-home-card-grid-adminlike">
            <article class="employee-home-entry-card employee-home-entry-card-warm" data-click-url="{{ path('employee_anomalies') }}">
                <div class="employee-home-entry-top">
                    <span class="employee-home-entry-icon employee-home-entry-icon-warm" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M22 18h20a10 10 0 0 1 10 10v8a10 10 0 0 1-10 10H30l-10 8v-8h-2a8 8 0 0 1-8-8V28a10 10 0 0 1 10-10Z" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M24 30h16M24 38h10" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                            <circle cx="48" cy="18" r="7" fill="currentColor"/>
                            <path d="M48 14.5v6M45 17.5h6" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="employee-home-entry-count">{{ anomalyCount }}</span>
                </div>
                <div class="employee-home-entry-copy">
                    <p class="employee-home-card-label">Mes anomalies</p>
                    <h4><a class="employee-home-title-link" href="{{ path('employee_anomalies') }}">Anomalies en cours</a></h4>
                    <p>
                        {% if anomalyCount > 0 %}
                            {{ anomalyCount }} anomalie{{ anomalyCount > 1 ? 's' : '' }} à suivre.
                        {% else %}
                            Tout est sous contrôle.
                        {% endif %}
                    </p>
                </div>
            </article>

            <article class="employee-home-entry-card employee-home-entry-card-soft">
                <div class="employee-home-entry-top">
                    <span class="employee-home-entry-icon employee-home-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <rect x="12" y="18" width="40" height="32" rx="12" fill="none" stroke="currentColor" stroke-width="4.2"/>
                            <path d="M12 28h40" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                            <path d="M22 14v8M42 14v8" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                            <circle cx="24" cy="38" r="3.5" fill="currentColor"/>
                            <path d="M34 38h10M24 46h20" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="employee-home-entry-count">{{ nextCheckout ? 1 : 0 }}</span>
                </div>
                <div class="employee-home-entry-copy">
                    <p class="employee-home-card-label">Mon prochain check-out</p>
                    <h4>{{ nextCheckout ? nextCheckout.apartment.name : 'Aucun check-out programmé' }}</h4>
                    <p>
                        {% if nextCheckout and nextCheckout.scheduledAt %}
                            {{ nextCheckoutDateLabel }}
                        {% else %}
                            Aucun rendez-vous après aujourd’hui.
                        {% endif %}
                    </p>
                </div>
            </article>

            <article class="employee-home-entry-card employee-home-entry-card-primary" data-click-url="{{ path('employee_apartments') }}">
                <div class="employee-home-entry-top">
                    <span class="employee-home-entry-icon employee-home-entry-icon-primary" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path d="M14 52V20a6 6 0 0 1 6-6h12v38H14Zm18 0V12a6 6 0 0 1 6-6h10a6 6 0 0 1 6 6v40H32Z" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linejoin="round"/>
                            <path d="M20 26h6M20 34h6M20 42h6M40 18h6M40 28h6M40 38h6" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="employee-home-entry-count">{{ apartments|length }}</span>
                </div>
                <div class="employee-home-entry-copy">
                    <p class="employee-home-card-label">Liste des appartements</p>
                    <h4><a class="employee-home-title-link" href="{{ path('employee_apartments') }}">Mes appartements</a></h4>
                    <p>{{ apartments|length }} appartement{{ apartments|length > 1 ? 's' : '' }} assigné{{ apartments|length > 1 ? 's' : '' }}.</p>
                </div>
            </article>

            <article class="employee-home-entry-card employee-home-entry-card-soft" data-click-url="{{ path('employee_profile') }}">
                <div class="employee-home-entry-top">
                    <span class="employee-home-entry-icon employee-home-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <circle cx="24" cy="24" r="8" fill="none" stroke="currentColor" stroke-width="4.2"/>
                            <path d="M12 46c2.4-7.5 8-12 16-12s13.6 4.5 16 12" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                            <path d="M46 20h8M46 30h6M46 40h8" fill="none" stroke="currentColor" stroke-width="4.2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="employee-home-entry-count">{{ activeServiceCount }}</span>
                </div>
                <div class="employee-home-entry-copy">
                    <p class="employee-home-card-label">Mes services extras</p>
                    <h4><a class="employee-home-title-link" href="{{ path('employee_profile') }}">Mon profil</a></h4>
                    <p>{{ activeServiceCount }} service{{ activeServiceCount > 1 ? 's' : '' }} actif{{ activeServiceCount > 1 ? 's' : '' }}.</p>
                </div>
            </article>
        </div>
    </section>
</div>
