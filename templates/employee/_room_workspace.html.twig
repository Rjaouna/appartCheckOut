<section class="room-check-group room-detail-panel">
    <div class="room-check-head">
        <div>
            <h2>{{ roomGroup.room.name }}</h2>
            <p>{{ roomGroup.room.type.label }}</p>
        </div>
        <div class="info-cluster">
            <a class="primary-button" href="{{ path('employee_checkout_show', {id: checkout.id}) }}">Retour aux pièces</a>
            <span class="progress-badge">{{ roomGroup.checkedCount }}/{{ roomGroup.totalCount }} contrôles</span>
            {% if roomGroup.anomalyCount > 0 %}
                <span class="status-badge is-warning">{{ roomGroup.anomalyCount }} anomalie{{ roomGroup.anomalyCount > 1 ? 's' : '' }}</span>
            {% else %}
                <span class="status-badge is-success">Aucune anomalie</span>
            {% endif %}
        </div>
    </div>

    {% for line in roomGroup.lines %}
        <article class="check-line {{ line.status ? 'is-complete' : 'is-open' }} {{ line.status and line.status.value == 'ok' ? 'is-ok' : '' }} {{ line.status and line.status.value != 'ok' ? 'is-issue' : '' }}">
            <div class="check-line-top">
                <div>
                    <strong>{{ line.roomEquipment.label }}</strong>
                    <p>{{ line.status ? line.status.label : 'À vérifier' }}</p>
                </div>
                {% if line.status %}
                    <span class="status-badge {{ line.status.value == 'ok' ? 'is-success' : 'is-warning' }}">{{ line.status.label }}</span>
                {% endif %}
                {% if line.photoPath %}
                    <a href="{{ line.photoPath }}" target="_blank" rel="noreferrer">Photo</a>
                {% endif %}
            </div>
            <form method="post" enctype="multipart/form-data" action="{{ path('employee_checkout_line_update', {id: line.id}) }}" class="stack-form compact-form" data-async-form data-update-target="#room-workspace">
                <div class="choice-grid">
                    {% for option in checkStatuses %}
                        <label class="choice-pill">
                            <input type="radio" name="status" value="{{ option.value }}" {{ line.status and line.status.value == option.value ? 'checked' : '' }} required>
                            <span>{{ option.label }}</span>
                        </label>
                    {% endfor %}
                </div>
                <textarea
                    name="comment"
                    rows="2"
                    placeholder="Commentaire obligatoire si anomalie ou non vérifié"
                    data-comment-field
                >{{ line.comment }}</textarea>
                <input type="file" name="photo" accept="image/*">
                <button class="primary-button" type="submit">Enregistrer</button>
            </form>
        </article>
    {% else %}
            <p class="empty-state">Aucun équipement à vérifier dans cette pièce.</p>
    {% endfor %}
</section>
