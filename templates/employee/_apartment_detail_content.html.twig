<div class="employee-apartment-detail-shell">
    <section class="employee-apartment-hero">
        <div class="employee-apartment-hero-copy">
            <div class="employee-apartment-head">
                <h2 class="employee-apartment-card-title">{{ apartment.name }}</h2>
            </div>
            <p><a class="address-link" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">{{ apartment.fullAddress }}</a></p>
        </div>
    </section>

    <div class="employee-apartment-detail-grid">
        <section class="apartment-detail-card apartment-detail-card-static">
            <h3>Accès</h3>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Étage</span>
                        <strong>{{ apartment.floor ?: '-' }}</strong>
                    </div>
                </div>
            </div>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Porte</span>
                        <strong>{{ apartment.doorNumber ?: '-' }}</strong>
                    </div>
                </div>
            </div>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Boîte aux lettres</span>
                        <strong>{{ apartment.mailboxNumber ?: '-' }}</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="apartment-detail-card">
            <h3>Codes</h3>
            {% include 'employee/_editable_apartment_field.html.twig' with {
                apartment: apartment,
                field: 'buildingAccessCode',
                label: 'Code immeuble',
                value: apartment.buildingAccessCode ?: '-',
                rawValue: apartment.buildingAccessCode ?: ''
            } %}
            {% include 'employee/_editable_apartment_field.html.twig' with {
                apartment: apartment,
                field: 'keyBoxCode',
                label: 'Code boîte à clés / code porte',
                value: apartment.keyBoxCode ?: '-',
                rawValue: apartment.keyBoxCode ?: ''
            } %}
        </section>

        <section class="apartment-detail-card apartment-detail-card-static">
            <h3>Navigation et contact</h3>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Google Maps</span>
                        <strong>
                            {% if apartment.googleMapsLink %}
                                <a class="inline-detail-link" href="{{ apartment.googleMapsLink }}" target="_blank" rel="noreferrer">Ouvrir</a>
                            {% else %}
                                -
                            {% endif %}
                        </strong>
                    </div>
                </div>
            </div>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Numéro de téléphone</span>
                        <strong>{{ apartment.ownerPhone ?: '-' }}</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="apartment-detail-card apartment-detail-card-wide apartment-detail-card-static">
            <h3>Consignes</h3>
            <div class="editable-field-row">
                <div class="editable-field-display">
                    <div class="editable-field-copy">
                        <span class="editable-field-label">Instructions d'entrée</span>
                        <strong>{{ apartment.entryInstructions ?: 'Aucune consigne pour le moment.' }}</strong>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
