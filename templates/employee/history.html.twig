{% extends 'base.html.twig' %}

{% block title %}Historique{% endblock %}

{% block body %}
    <section class="page-head employee-page-head">
        <div>
            <h1>Historique</h1>
            <p class="muted">Retrouve ici tes check-outs déjà terminés ou clôturés.</p>
        </div>
        <div class="head-actions">
            <a class="secondary-button" href="{{ path('employee_dashboard') }}">Retour</a>
        </div>
    </section>

    <section class="employee-list-stack">
        {% for checkout in historyCheckouts %}
            <article class="employee-list-card">
                <div class="employee-list-card-top">
                    <span class="status-badge">{{ checkout.status.label }}</span>
                    {% if checkout.completedAt %}
                        <span class="mini-badge">{{ checkout.completedAt|date('d/m/Y H:i') }}</span>
                    {% endif %}
                </div>
                <h2>{{ checkout.apartment.name }}</h2>
                <p>{{ checkout.apartment.fullAddress }}</p>
                <div class="employee-list-card-meta">
                    <span>Planifié : {{ checkout.scheduledAt ? checkout.scheduledAt|date('d/m/Y H:i') : 'Non renseigné' }}</span>
                    <span>Progression finale : {{ checkout.progressPercent }}%</span>
                </div>
                {% if checkout.anomalies|length > 0 %}
                    <div class="employee-anomaly-summary">
                        {% for anomaly in checkout.anomalies %}
                            <div>
                                <strong>{{ anomaly.room.name }}</strong>
                                <span>{{ anomaly.roomEquipment.label }}</span>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="muted">Aucune anomalie sur ce check-out.</p>
                {% endif %}
                <a class="secondary-button full-width" href="{{ path('employee_checkout_show', {id: checkout.id}) }}">Voir le detail</a>
            </article>
        {% else %}
            <p class="empty-state">Aucun historique disponible pour le moment.</p>
        {% endfor %}
    </section>
{% endblock %}
