{% extends 'base.html.twig' %}

{% block title %}Anomalies declarees{% endblock %}

{% block body %}
    <section class="page-head employee-page-head">
        <div>
            <h1>Anomalies declarees</h1>
        </div>
        <div class="head-actions">
            <a class="primary-button" href="{{ path('employee_dashboard') }}">Retour</a>
        </div>
    </section>

    <section class="employee-list-stack">
        {% for anomaly in anomalies %}
            {% include 'employee/_anomaly_card.html.twig' with { anomaly: anomaly } only %}
        {% else %}
            <p class="empty-state">Aucune anomalie ouverte pour le moment.</p>
        {% endfor %}
    </section>
{% endblock %}
