{% extends 'base.html.twig' %}

{% block title %}Anomalies{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <span class="eyebrow">Suivi anomalies</span>
            <h1>Anomalies</h1>
            <p class="muted">Vue rapide des appartements qui demandent une action.</p>
        </div>
        <div class="head-actions">
            <a class="secondary-button app-back-button" href="{{ path('admin_dashboard') }}">Retour</a>
        </div>
    </section>

    <section class="admin-anomalies-focus-grid">
        {% for card in apartmentCards %}
            {% set apartment = card.apartment %}
            {% set assignedEmployees = card.assignedEmployees %}
            {% set leadEmployee = assignedEmployees|length > 0 ? assignedEmployees|first : null %}
            {% set extraManagers = assignedEmployees|length > 1 ? assignedEmployees|slice(1) : [] %}
            {% set latestAnomaly = card.latestOpenAnomaly %}
            {% set visibleRooms = card.affectedRooms|slice(0, 3) %}
            {% set hiddenRoomCount = card.affectedRooms|length - visibleRooms|length %}

            <article class="admin-anomaly-summary-card {{ card.priorityOpenAnomalyCount > 0 ? 'is-priority' : '' }}">
                <div class="admin-anomaly-summary-head">
                    <div>
                        <span class="admin-anomaly-card-kicker">Appartement</span>
                        <h2>
                            <a href="{{ path('admin_apartment_anomalies', {id: apartment.id}) }}">{{ apartment.name }}</a>
                        </h2>
                    </div>
                    <span class="admin-anomaly-count-badge" aria-label="{{ card.openAnomalyCount }} anomalies ouvertes">
                        <strong>{{ card.openAnomalyCount }}</strong>
                        <span>ouverte{{ card.openAnomalyCount > 1 ? 's' : '' }}</span>
                    </span>
                </div>

                <div class="admin-anomaly-signal-row">
                    {% if card.priorityOpenAnomalyCount > 0 %}
                        <span class="admin-anomaly-signal is-danger">{{ card.priorityOpenAnomalyCount }} prioritaire{{ card.priorityOpenAnomalyCount > 1 ? 's' : '' }}</span>
                    {% endif %}
                    {% if card.newOpenAnomalyCount > 0 %}
                        <span class="admin-anomaly-signal is-warning">{{ card.newOpenAnomalyCount }} nouvelle{{ card.newOpenAnomalyCount > 1 ? 's' : '' }}</span>
                    {% endif %}
                    {% if card.followedOpenAnomalyCount > 0 %}
                        <span class="admin-anomaly-signal is-success">{{ card.followedOpenAnomalyCount }} en suivi</span>
                    {% endif %}
                </div>

                {% if latestAnomaly %}
                    <div class="admin-anomaly-latest-box">
                        <span>Dernière anomalie</span>
                        <strong>{{ latestAnomaly.roomEquipment.displayLabel }}</strong>
                        <p>{{ latestAnomaly.room.name }} · {{ latestAnomaly.type.label }} · {{ latestAnomaly.createdAt|date('d/m/Y H:i') }}</p>
                    </div>
                {% endif %}

                <div class="admin-anomaly-room-strip">
                    <span>Pièces concernées</span>
                    <div>
                        {% for room in visibleRooms %}
                            <span class="admin-anomaly-room-chip">{{ room.name }} <strong>{{ room.count }}</strong></span>
                        {% else %}
                            <span class="muted">Non renseigné</span>
                        {% endfor %}
                        {% if hiddenRoomCount > 0 %}
                            <span class="admin-anomaly-room-chip is-more">+{{ hiddenRoomCount }}</span>
                        {% endif %}
                    </div>
                </div>

                <footer class="admin-anomaly-summary-footer">
                    <div class="admin-anomaly-compact-manager">
                        <span>Responsable</span>
                        {% if leadEmployee %}
                            <a href="{{ path('admin_user_show', {id: leadEmployee.id}) }}">{{ leadEmployee.fullName }}</a>
                            {% if extraManagers|length > 0 %}
                                <small>+{{ extraManagers|length }} autre{{ extraManagers|length > 1 ? 's' : '' }}</small>
                            {% endif %}
                        {% else %}
                            <strong>Non assigné</strong>
                        {% endif %}
                    </div>

                    <a class="primary-button admin-anomaly-open-button" href="{{ path('admin_apartment_anomalies', {id: apartment.id}) }}">
                        Ouvrir le suivi
                    </a>
                </footer>
            </article>
        {% else %}
            <p class="empty-state">Aucune anomalie en cours.</p>
        {% endfor %}
    </section>

    <section class="panel admin-anomalies-history-panel">
        <div class="panel-head">
            <div>
                <h2>Historique des anomalies</h2>
                <p class="muted">Anomalies clôturées enregistrées pour le suivi et les statistiques.</p>
            </div>
        </div>
        <form method="get" class="admin-history-filters">
            <label>
                <span>Appartement</span>
                <select name="historyApartment" onchange="this.form.submit()">
                    <option value="0">Tous les appartements</option>
                    {% for apartment in historyFilterApartments %}
                        <option value="{{ apartment.id }}" {{ selectedHistoryApartmentId == apartment.id ? 'selected' : '' }}>
                            {{ apartment.name }}
                        </option>
                    {% endfor %}
                </select>
            </label>
            <label>
                <span>Responsable</span>
                <select name="historyUser" onchange="this.form.submit()">
                    <option value="0">Tous les responsables</option>
                    {% for user in historyFilterUsers %}
                        <option value="{{ user.id }}" {{ selectedHistoryUserId == user.id ? 'selected' : '' }}>
                            {{ user.fullName }}
                        </option>
                    {% endfor %}
                </select>
            </label>
            <noscript>
                <button class="secondary-button" type="submit">Filtrer</button>
            </noscript>
        </form>
        <div class="room-selector-grid">
            {% for anomaly in historyAnomalies %}
                <a class="room-selector-card admin-apartment-card" href="{{ path('admin_anomaly_detail', {id: anomaly.id}) }}">
                    <div class="room-selector-top">
                        {% include 'admin/_apartment_icon.html.twig' %}
                        <span class="status-badge is-success">{{ anomaly.status.label }}</span>
                    </div>
                    <strong>{{ anomaly.roomEquipment.displayLabel }}</strong>
                    <p>{{ anomaly.apartment.name }}</p>
                    <div class="card-detail-list">
                        <span>Responsable : {{ anomaly.createdBy.fullName }}</span>
                        <span>Pièce : {{ anomaly.room.name }}</span>
                        <span>Clôturée : {{ anomaly.closedAt ? anomaly.closedAt|date('d/m/Y H:i') : '-' }}</span>
                    </div>
                </a>
            {% else %}
                <p class="empty-state">Aucune anomalie clôturée pour le moment.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
