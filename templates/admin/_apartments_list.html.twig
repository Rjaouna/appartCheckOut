<div id="apartments-list-panel" class="panel admin-apartments-list-panel">
    <div class="admin-home-section-head compact">
        <div>
            <h2>Liste des appartements</h2>
            <p>{{ apartments|length }} appartement{{ apartments|length > 1 ? 's' : '' }} dans le parc admin</p>
        </div>
    </div>
    <div class="card-grid apartment-card-grid admin-home-apartment-grid">
        {% for apartment in apartments %}
            {% set activeManagers = apartment.assignedEmployees|filter(employee => 'ROLE_ADMIN' not in employee.roles) %}
            {% set leadManager = activeManagers|first %}
            {% set extraManagerCount = activeManagers|length > 1 ? activeManagers|length - 1 : 0 %}
            {% set managerListId = 'admin-apartment-managers-' ~ apartment.id %}
            {% set accessCode = apartment.keyBoxCode ?: apartment.buildingAccessCode ?: 'Non renseigné' %}
            <article class="employee-card admin-apartment-card admin-home-card {{ apartment.status.value != 'active' ? 'is-dimmed' : '' }}" data-click-url="{{ path('admin_apartment_show', {id: apartment.id}) }}">
                <div class="apartment-topline">
                    <div class="card-top-actions">
                        {% if apartment.isInventoryPriority %}
                            <span class="priority-pill">Inventaire prioritaire</span>
                        {% endif %}
                        {% set openAnomalyCount = openAnomalyCounts[apartment.id] ?? 0 %}
                        {% if openAnomalyCount > 0 %}
                            <span class="mini-badge is-warning">{{ openAnomalyCount }} anomalie{{ openAnomalyCount > 1 ? 's' : '' }}</span>
                        {% endif %}
                    </div>
                </div>
                <h2 class="card-title-link-wrap"><a class="card-title-link" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">{{ apartment.name }}</a></h2>
                <div class="apartment-card-info-stack">
                    <a class="address-link apartment-card-address-link" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">{{ apartment.fullAddress }}</a>
                    <dl class="key-values apartment-card-meta-grid">
                        <div>
                            <dt>Code d’accès</dt>
                            <dd>{{ accessCode }}</dd>
                        </div>
                        <div>
                            <dt>Gérants</dt>
                            <dd>
                                {% if leadManager %}
                                    <a class="apartment-manager-link" href="{{ path('admin_user_show', {id: leadManager.id}) }}">{{ leadManager.fullName }}</a>
                                    {% if extraManagerCount > 0 %}
                                        <button
                                            class="apartment-manager-toggle"
                                            type="button"
                                            data-toggle-target="#{{ managerListId }}"
                                            data-toggle-label-open="(+{{ extraManagerCount }} autre{{ extraManagerCount > 1 ? 's' : '' }})"
                                            data-toggle-label-closed="(+{{ extraManagerCount }} autre{{ extraManagerCount > 1 ? 's' : '' }})"
                                        >
                                            (+{{ extraManagerCount }} autre{{ extraManagerCount > 1 ? 's' : '' }})
                                        </button>
                                    {% endif %}
                                {% else %}
                                    <span class="muted">Aucun employé assigné</span>
                                {% endif %}
                            </dd>
                        </div>
                    </dl>
                    {% if extraManagerCount > 0 %}
                        <div id="{{ managerListId }}" class="apartment-manager-list is-collapsed">
                            {% for employee in activeManagers|slice(1) %}
                                <a class="apartment-manager-link" href="{{ path('admin_user_show', {id: employee.id}) }}">{{ employee.fullName }}</a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <p class="empty-state">Aucun appartement créé pour le moment.</p>
        {% endfor %}
    </div>
</div>
