<div id="apartments-list-panel" class="panel admin-apartments-list-panel">
    <div class="admin-apartments-list-head">
        <div>
            <span class="employee-home-kicker">Parc immobilier</span>
            <h2>Liste des appartements</h2>
            <p>{{ apartments|length }} appartement{{ apartments|length > 1 ? 's' : '' }} dans le parc admin</p>
        </div>
        <span class="admin-apartments-count">{{ apartments|length }}</span>
    </div>

    <div class="card-grid apartment-card-grid admin-home-apartment-grid admin-apartments-grid">
        {% set airbnbBadges = airbnbCheckBadges|default({}) %}
        {% for apartment in apartments %}
            {% set activeManagers = apartment.assignedEmployees|filter(employee => 'ROLE_ADMIN' not in employee.roles) %}
            {% set keyBoxCode = apartment.keyBoxCode ?: 'Non renseigné' %}
            {% set openAnomalyCount = openAnomalyCounts[apartment.id] ?? 0 %}
            {% set airbnbBadge = airbnbBadges[apartment.id] ?? {label: 'Non audité', class: 'is-neutral'} %}
            <article class="admin-apartment-card admin-apartment-list-card {{ apartment.status.value != 'active' ? 'is-dimmed' : '' }}" data-click-url="{{ path('admin_apartment_show', {id: apartment.id}) }}">
                <div class="admin-apartment-card-glow" aria-hidden="true"></div>

                <div class="admin-apartment-card-media">
                    <img src="{{ asset(apartment.imagePath ?: '/img/ecrans/appartement.png') }}" alt="{{ apartment.name }}">
                    {% if activeManagers|length > 0 %}
                        <div class="admin-apartment-card-avatars" aria-label="Employés associés">
                            {% for employee in activeManagers|slice(0, 4) %}
                                <a class="admin-apartment-card-avatar {{ employee.photoPath ? 'has-photo' : '' }}" href="{{ path('admin_user_show', {id: employee.id}) }}" title="{{ employee.fullName }}" aria-label="Voir la fiche de {{ employee.fullName }}">
                                    {% if employee.photoPath %}
                                        <img src="{{ employee.photoPath }}" alt="{{ employee.fullName }}">
                                    {% else %}
                                        {{ employee.fullName|first|upper }}
                                    {% endif %}
                                </a>
                            {% endfor %}
                            {% if activeManagers|length > 4 %}
                                <span class="admin-apartment-card-avatar admin-apartment-card-avatar-more" title="{{ activeManagers|length - 4 }} employé{{ activeManagers|length - 4 > 1 ? 's' : '' }} supplémentaire{{ activeManagers|length - 4 > 1 ? 's' : '' }}">+{{ activeManagers|length - 4 }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>

                <header class="admin-apartment-card-header">
                    <div class="admin-apartment-card-title">
                        <div class="admin-apartment-card-badges">
                            <span class="status-badge {{ apartment.status.value == 'active' ? 'is-success' : 'is-neutral' }}">{{ apartment.status.label }}</span>
                            <span class="airbnb-audit-badge {{ airbnbBadge.class }}">{{ airbnbBadge.label }}</span>
                            {% if apartment.isInventoryPriority %}
                                <span class="priority-pill">Inventaire prioritaire</span>
                            {% endif %}
                            {% if openAnomalyCount > 0 %}
                                <span class="mini-badge is-warning">{{ openAnomalyCount }} anomalie{{ openAnomalyCount > 1 ? 's' : '' }}</span>
                            {% endif %}
                        </div>
                        <h3><a class="card-title-link" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">{{ apartment.name }}</a></h3>
                        <a class="admin-apartment-address-link" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7Zm0 9.6A2.6 2.6 0 1 1 12 6.4a2.6 2.6 0 0 1 0 5.2Z" fill="currentColor"/>
                            </svg>
                            <span>{{ apartment.fullAddress }}</span>
                        </a>
                    </div>
                </header>

                <div class="admin-apartment-card-stats">
                    <div>
                        <span>Code porte</span>
                        <strong>{{ keyBoxCode }}</strong>
                    </div>
                </div>

                <footer class="admin-apartment-card-footer">
                    <span>{{ apartment.city }}</span>
                    <a class="admin-apartment-card-cta" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">
                        Voir la fiche
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M8 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </a>
                </footer>
            </article>
        {% else %}
            <p class="empty-state">Aucun appartement créé pour le moment.</p>
        {% endfor %}
    </div>
</div>
