<div class="editable-field-row editable-field-row-compact">
    <div class="editable-field-display">
        <div class="editable-field-copy">
            <span class="editable-field-label">{{ label }}</span>
            <strong>{{ value }}</strong>
        </div>
        <button
            class="inline-edit-button"
            type="button"
            aria-label="Modifier {{ label }}"
            data-edit-target="#admin-editable-reservation-form-{{ reservation.id }}-{{ field }}"
        >
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 17.3V20h2.7l8-8-2.7-2.7-8 8ZM18.7 8a1 1 0 0 0 0-1.4l-1.3-1.3a1 1 0 0 0-1.4 0l-1.2 1.2 2.7 2.7L18.7 8Z" fill="currentColor"/>
            </svg>
        </button>
    </div>

    <form
        id="admin-editable-reservation-form-{{ reservation.id }}-{{ field }}"
        class="editable-field-form is-collapsed"
        method="post"
        action="{{ path('admin_reservation_field_update', {id: reservation.id}) }}"
        data-async-form
        data-update-target="{{ updateTarget }}"
    >
        <input type="hidden" name="field" value="{{ field }}">
        <input type="hidden" name="context" value="{{ context }}">
        {% if section is defined and section %}
            <input type="hidden" name="section" value="{{ section }}">
        {% endif %}
        <input type="text" name="value" value="{{ rawValue }}">
        <div class="editable-field-actions">
            <button class="primary-button" type="submit">Enregistrer</button>
            <button class="secondary-button" type="button" data-edit-target="#admin-editable-reservation-form-{{ reservation.id }}-{{ field }}">Annuler</button>
        </div>
    </form>
</div>
