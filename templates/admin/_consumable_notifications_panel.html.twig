<div class="consumable-notification-panel-head">
    <div>
        <span class="employee-home-kicker">Stocks consommables</span>
        <h3>Centre de notifications</h3>
        <p>{{ consumableRestockAlerts|length > 0 ? 'Stocks faibles et consommables à réapprovisionner.' : 'Tout est à jour pour le moment.' }}</p>
    </div>
    <span class="status-badge {{ consumableRestockAlerts|length > 0 ? 'is-warning' : 'is-success' }}">
        {{ consumableRestockAlerts|length }} alerte{{ consumableRestockAlerts|length > 1 ? 's' : '' }}
    </span>
</div>

{% if consumableRestockAlerts|length > 0 %}
    <div class="consumable-notification-list">
        {% for alert in consumableRestockAlerts %}
            {% set item = alert.item %}
            <article class="consumable-notification-item {{ alert.status.value == 'missing' ? 'is-danger' : 'is-warning' }}">
                <div class="consumable-notification-item-top">
                    <span class="consumable-notification-icon" aria-hidden="true">
                        <i class="bi {{ alert.status.value == 'missing' ? 'bi-exclamation-octagon-fill' : 'bi-exclamation-triangle-fill' }}"></i>
                    </span>
                    <div>
                        <strong>{{ item.name }}</strong>
                        <p>{{ alert.apartment.name }}</p>
                    </div>
                    <span class="consumable-notification-state {{ alert.status.value == 'missing' ? 'is-danger' : 'is-warning' }}">
                        {{ alert.status.label }}
                    </span>
                </div>

                <div class="consumable-notification-stock">
                    <div>
                        <span>Actuel</span>
                        <strong>{{ item.currentQuantity is not null ? item.currentQuantity : (alert.quantity is not null ? alert.quantity : 0) }}{% if item.unit %} {{ item.unit }}{% endif %}</strong>
                    </div>
                    <div>
                        <span>Minimum</span>
                        <strong>{{ item.minimumQuantity > 0 ? item.minimumQuantity : 1 }}{% if item.unit %} {{ item.unit }}{% endif %}</strong>
                    </div>
                </div>

                {% if alert.note %}
                    <p class="consumable-notification-note">{{ alert.note }}</p>
                {% endif %}

                <form method="post" action="{{ path(alert.restockRoute, alert.routeParams) }}" class="consumable-notification-restock-form" data-consumable-restock-form>
                    <input type="hidden" name="context" value="topbar">
                    <label>
                        <span>Réapprovisionnement</span>
                        <input type="number" name="addedQuantity" min="1" inputmode="numeric" placeholder="Ex. 5" required>
                    </label>
                    <button class="primary-button" type="submit">
                        <i class="bi bi-plus-circle-fill" aria-hidden="true"></i>
                        Ajouter au stock
                    </button>
                </form>
            </article>
        {% endfor %}
    </div>
{% else %}
    <div class="consumable-notification-empty">
        <span class="consumable-notification-empty-icon" aria-hidden="true">
            <i class="bi bi-check2-circle"></i>
        </span>
        <strong>Aucun stock à réapprovisionner</strong>
        <p>Toutes les alertes consommables sont à jour.</p>
    </div>
{% endif %}
