<div class="admin-users-layout">
    <section class="panel admin-users-form-panel">
        <div class="admin-home-section-head compact">
            <div>
                <h2>Ajouter un employé</h2>
                <p>Créer un accès terrain avec photo et contact direct.</p>
            </div>
            <button class="primary-button" type="button" data-edit-target="#admin-create-employee-form">Ajouter un employé</button>
        </div>

        <form
            id="admin-create-employee-form"
            method="post"
            action="{{ path('admin_user_create') }}"
            class="stack-form editable-field-form is-collapsed admin-users-create-form"
            enctype="multipart/form-data"
            data-async-form
            data-update-target="#admin-users-content"
            data-reset-form
        >
            <div class="form-grid two-columns">
                <label>
                    <span>Nom complet</span>
                    <input type="text" name="fullName" required>
                </label>
                <label>
                    <span>Email</span>
                    <input type="email" name="email" required>
                </label>
                <label>
                    <span>Numéro de téléphone</span>
                    <input type="tel" name="phoneNumber" placeholder="06 00 00 00 00">
                </label>
                <label>
                    <span>Mot de passe</span>
                    <input type="text" name="password" required>
                </label>
            </div>

            <label>
                <span>Photo</span>
                <input type="file" name="photo" accept="image/*">
            </label>

            <div class="admin-user-options">
                <label class="checkbox-row">
                    <input type="checkbox" name="isActive" value="1" checked>
                    <span>Compte actif</span>
                </label>
                <label class="checkbox-row">
                    <input type="checkbox" name="canManageAnomalyWorkflow" value="1">
                    <span>Gérer le suivi des anomalies</span>
                </label>
            </div>

            <div class="editable-field-actions">
                <button class="primary-button" type="submit">Créer l’employé</button>
                <button class="secondary-button" type="button" data-edit-target="#admin-create-employee-form">Annuler</button>
            </div>
        </form>
    </section>

    <section class="panel admin-users-list-panel">
        <div class="admin-home-section-head compact">
            <div>
                <h2>Équipe</h2>
                <p>Photo, contact rapide et accès détail.</p>
            </div>
            <span class="mini-badge">{{ users|length }} compte{{ users|length > 1 ? 's' : '' }}</span>
        </div>

        <div class="admin-users-grid admin-users-grid-compact">
            {% for user in users %}
                <article class="employee-card admin-user-list-card {{ not user.isActive ? 'is-muted' : '' }}">
                    <div class="admin-user-list-main">
                        <div class="admin-user-avatar {{ user.photoPath ? 'has-photo' : '' }}">
                            {% if user.photoPath %}
                                <img src="{{ user.photoPath }}" alt="{{ user.fullName }}">
                            {% else %}
                                <span>{{ user.fullName|slice(0, 1)|upper }}</span>
                            {% endif %}
                        </div>

                        <div class="admin-user-list-copy">
                            <h3><a class="admin-user-name-link" href="{{ path('admin_user_show', {id: user.id}) }}">{{ user.fullName }}</a></h3>
                            {% if user.phoneNumber %}
                                <a class="inline-detail-link admin-user-phone-link" href="tel:{{ user.phoneNumber }}">{{ user.phoneNumber }}</a>
                            {% else %}
                                <p class="muted">Numéro non renseigné</p>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% else %}
                <p class="empty-state">Aucun employé enregistré pour le moment.</p>
            {% endfor %}
        </div>
    </section>
</div>
