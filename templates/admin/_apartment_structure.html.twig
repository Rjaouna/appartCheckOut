{% set assignableEmployeeCount = 0 %}
{% for employee in apartment.assignedEmployees %}
    {% if 'ROLE_ADMIN' not in employee.roles %}
        {% set assignableEmployeeCount = assignableEmployeeCount + 1 %}
    {% endif %}
{% endfor %}

<section class="admin-apartment-workspace">
    <aside class="admin-apartment-nav">
        <div class="admin-apartment-nav-head">
            <span class="eyebrow">Parcours simple</span>
            <h2>Tout gérer depuis cette fiche</h2>
            <p>Commence par le check-out, puis complète l’accès, l’équipe et la structure si besoin.</p>
        </div>

        <div class="admin-apartment-nav-grid">
            <button class="admin-detail-entry-card admin-detail-entry-card-primary is-active" type="button" data-panel-open="#apartment-panel-checkout" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-checkout">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6v-2Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">{{ activeCheckouts|length > 0 ? activeCheckouts|length : 'Nouveau' }}</span>
                </div>
                <span class="admin-detail-entry-kicker">Étape 1</span>
                <strong>Check-out</strong>
                <p>Créer, programmer, suivre ou annuler un check-out sur cet appartement.</p>
            </button>

            <button class="admin-detail-entry-card admin-detail-entry-card-soft" type="button" data-panel-open="#apartment-panel-access" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-access">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon admin-detail-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 21s7-4.4 7-11a7 7 0 1 0-14 0c0 6.6 7 11 7 11Z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"/>
                            <circle cx="12" cy="10" r="2.5" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">Accès</span>
                </div>
                <span class="admin-detail-entry-kicker">Étape 2</span>
                <strong>Adresse et codes</strong>
                <p>Retrouver vite l’adresse, les codes et les consignes d’entrée.</p>
            </button>

            <button class="admin-detail-entry-card admin-detail-entry-card-soft" type="button" data-panel-open="#apartment-panel-assignment" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-assignment">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon admin-detail-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4ZM8 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm8 2c-2.67 0-8 1.34-8 4v3h16v-3c0-2.66-5.33-4-8-4ZM8 13c-.29 0-.62.02-.97.05C4.42 13.27 0 14.44 0 17v3h6v-3c0-1.16.55-2.18 1.53-3A8.63 8.63 0 0 1 8 13Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">{{ apartment.assignedEmployees|length }}</span>
                </div>
                <span class="admin-detail-entry-kicker">Étape 3</span>
                <strong>Équipe et priorité</strong>
                <p>Choisir les employés et mettre l’appartement en tête de liste si nécessaire.</p>
            </button>

            <button class="admin-detail-entry-card admin-detail-entry-card-soft" type="button" data-panel-open="#apartment-panel-rooms" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-rooms">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon admin-detail-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3v-10.5Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">{{ apartment.activeRooms|length }}</span>
                </div>
                <span class="admin-detail-entry-kicker">Étape 4</span>
                <strong>Pièces et équipements</strong>
                <p>Construire la checklist pièce par pièce et garder une base propre.</p>
            </button>

            <button class="admin-detail-entry-card admin-detail-entry-card-soft" type="button" data-panel-open="#apartment-panel-anomalies" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-anomalies">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon admin-detail-entry-icon-warning" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 2 1 21h22L12 2Zm1 14h-2v-2h2v2Zm0-4h-2V8h2v4Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">{{ anomalyCount }}</span>
                </div>
                <span class="admin-detail-entry-kicker">Suivi</span>
                <strong>Anomalies</strong>
                <p>Voir les pièces touchées et ouvrir le détail du suivi en un clic.</p>
            </button>

            <button class="admin-detail-entry-card admin-detail-entry-card-danger" type="button" data-panel-open="#apartment-panel-settings" data-panel-group="apartment-admin" data-panel-trigger="#apartment-panel-settings">
                <div class="admin-detail-entry-head">
                    <span class="admin-detail-entry-icon admin-detail-entry-icon-danger" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 9v4m0 4h.01M10.3 3.9 1.8 18.3A2 2 0 0 0 3.5 21h17a2 2 0 0 0 1.7-2.7L13.7 3.9a2 2 0 0 0-3.4 0Z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                    <span class="admin-detail-entry-metric">{{ apartment.status.label }}</span>
                </div>
                <span class="admin-detail-entry-kicker">Pilotage</span>
                <strong>Statut et archivage</strong>
                <p>Mettre l’appartement en pause, l’archiver ou le supprimer si besoin.</p>
            </button>
        </div>
    </aside>

    <div class="admin-apartment-panels">
        <div class="admin-apartment-summary">
            <article class="admin-apartment-summary-card">
                <span class="admin-apartment-summary-label">À faire maintenant</span>
                <strong>{{ activeCheckouts|length > 0 ? 'Suivre le check-out déjà ouvert' : 'Créer le prochain check-out' }}</strong>
            </article>
            <article class="admin-apartment-summary-card">
                <span class="admin-apartment-summary-label">Équipe assignée</span>
                <strong>{{ apartment.assignedEmployees|length > 0 ? apartment.assignedEmployees|length ~ ' employé' ~ (apartment.assignedEmployees|length > 1 ? 's' : '') : 'Aucun employé assigné' }}</strong>
            </article>
            <article class="admin-apartment-summary-card">
                <span class="admin-apartment-summary-label">Anomalies ouvertes</span>
                <strong>{{ anomalyCount }} anomalie{{ anomalyCount > 1 ? 's' : '' }}</strong>
            </article>
        </div>

        <div id="apartment-panel-checkout" class="panel span-two admin-detail-panel" data-panel-group="apartment-admin" data-panel-name="checkout">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Check-out</span>
                    <h2>Lancer et suivre les check-outs</h2>
                    <p>Cette zone sert à programmer un nouveau passage, puis à garder la main sur les check-outs déjà ouverts.</p>
                </div>
                <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-checkout">Retour</button>
            </div>

            <div class="admin-detail-section-grid">
                <article class="admin-detail-focus-card admin-detail-focus-card-primary">
                    <div class="admin-detail-focus-head">
                        <div>
                            <span class="admin-detail-focus-kicker">Action principale</span>
                            <h3>Créer un check-out</h3>
                        </div>
                        <span class="status-badge">{{ hasOpenCheckout ? 'Déjà ouvert' : 'Disponible' }}</span>
                    </div>

                    {% if hasOpenCheckout %}
                        <div class="empty-state">
                            Un check-out non terminé existe déjà pour cet appartement. Termine-le ou annule-le avant d’en créer un nouveau.
                        </div>
                    {% elseif assignableEmployeeCount == 0 %}
                        <div class="empty-state">
                            Assigne d’abord au moins un employé terrain à cet appartement pour pouvoir créer un check-out.
                        </div>
                    {% else %}
                        <form method="post" action="{{ path('admin_checkout_create', {id: apartment.id}) }}" class="stack-form admin-detail-form-card" data-async-form data-update-target="#apartment-detail-root">
                            <label><span>Employé</span>
                                <select name="assignedTo" required>
                                    {% for employee in apartment.assignedEmployees %}
                                        {% if 'ROLE_ADMIN' not in employee.roles %}
                                            <option value="{{ employee.id }}">{{ employee.fullName }}</option>
                                        {% endif %}
                                    {% endfor %}
                                </select>
                            </label>
                            <label><span>Date prévue</span><input type="datetime-local" name="scheduledAt"></label>
                            <label><span>Priorité</span>
                                <select name="priority">
                                    <option value="normal">Normale</option>
                                    <option value="high">Haute</option>
                                    <option value="urgent">Urgente</option>
                                </select>
                            </label>
                            <button class="primary-button" type="submit">Créer le check-out</button>
                        </form>
                    {% endif %}
                </article>

                <article class="admin-detail-focus-card">
                    <div class="admin-detail-focus-head">
                        <div>
                            <span class="admin-detail-focus-kicker">Suivi en direct</span>
                            <h3>Check-outs déjà ouverts</h3>
                        </div>
                        <span class="status-badge is-soft">{{ activeCheckouts|length }}</span>
                    </div>

                    <div class="mini-list">
                        {% for checkout in activeCheckouts %}
                            <article class="compact-card compact-card-modern">
                                <div class="admin-detail-inline-top">
                                    <strong>{{ checkout.assignedTo.fullName }}</strong>
                                    <span class="status-badge">{{ checkout.status.label }}</span>
                                </div>
                                <p>{{ checkout.scheduledAt ? checkout.scheduledAt|date('d/m/Y H:i') : '-' }}</p>
                                <form method="post" action="{{ path('admin_checkout_schedule_update', {id: checkout.id}) }}" class="stack-form compact-form checkout-action-form" data-async-form data-update-target="#apartment-detail-root">
                                    <label>
                                        <span>Modifier la date prévue</span>
                                        <input type="datetime-local" name="scheduledAt" value="{{ checkout.scheduledAt ? checkout.scheduledAt|date('Y-m-d\\TH:i') : '' }}" required>
                                    </label>
                                    <button class="secondary-button" type="submit">Mettre à jour la date</button>
                                </form>
                                {% if checkout.status.value not in ['completed', 'cancelled'] %}
                                    <form
                                        method="post"
                                        action="{{ path('admin_checkout_cancel', {id: checkout.id}) }}"
                                        class="compact-form checkout-action-form"
                                        data-async-form
                                        data-update-target="#apartment-detail-root"
                                        data-confirm-reset
                                        data-confirm-title="Annuler le check-out"
                                        data-confirm-message="Veux-tu vraiment annuler ce check-out ?"
                                    >
                                        <button class="secondary-button danger-button" type="submit">Annuler le check-out</button>
                                    </form>
                                {% endif %}
                            </article>
                        {% else %}
                            <p class="empty-state">Aucun check-out en cours ou programmé.</p>
                        {% endfor %}
                    </div>
                </article>
            </div>

            <div class="admin-detail-subsection">
                <div class="panel-head admin-subsection-head">
                    <h3>Historique des check-outs terminés</h3>
                </div>
                <div class="mini-list">
                    {% for checkout in completedCheckouts %}
                        <article class="compact-card compact-card-modern">
                            <strong>{{ checkout.assignedTo.fullName }}</strong>
                            <p>{{ checkout.completedAt ? checkout.completedAt|date('d/m/Y H:i') : (checkout.scheduledAt ? checkout.scheduledAt|date('d/m/Y H:i') : '-') }}</p>
                            {% if checkout.anomalies|length > 0 %}
                                <div class="card-detail-list">
                                    {% for anomaly in checkout.anomalies %}
                                        <span>{{ anomaly.room.name }} : {{ anomaly.roomEquipment.label }}</span>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="muted">Aucune anomalie.</p>
                            {% endif %}
                        </article>
                    {% else %}
                        <p class="empty-state">Aucun check-out terminé.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div id="apartment-panel-access" class="panel span-two admin-detail-panel is-collapsed" data-panel-group="apartment-admin" data-panel-name="access">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Accès</span>
                    <h2>Adresse, codes et consignes</h2>
                    <p>Les informations sont regroupées par usage pour éviter de chercher dans toute la fiche.</p>
                </div>
                <div class="admin-detail-panel-actions">
                    <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-access">Retour</button>
                </div>
            </div>

            <div class="admin-detail-section-grid">
                <section class="admin-detail-focus-card">
                    <div class="admin-detail-focus-head">
                        <div>
                            <span class="admin-detail-focus-kicker">Repères</span>
                            <h3>Adresse et emplacement</h3>
                        </div>
                    </div>
                    <div class="info-list admin-detail-info-group">
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'addressLine1', label: 'Adresse', value: apartment.addressLine1, rawValue: apartment.addressLine1, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'addressLine2', label: 'Complément d’adresse', value: apartment.addressLine2 ?: 'Non renseigné', rawValue: apartment.addressLine2, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'city', label: 'Ville', value: apartment.city, rawValue: apartment.city, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'postalCode', label: 'Code postal', value: apartment.postalCode ?: 'Non renseigné', rawValue: apartment.postalCode, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'floor', label: 'Étage', value: apartment.floor ?: 'Non renseigné', rawValue: apartment.floor, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'doorNumber', label: 'Porte', value: apartment.doorNumber ?: 'Non renseigné', rawValue: apartment.doorNumber, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'mailboxNumber', label: 'Boîte aux lettres', value: apartment.mailboxNumber ?: 'Non renseigné', rawValue: apartment.mailboxNumber, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'googleMapsLink', label: 'Google Maps', value: apartment.googleMapsLink ?: 'Non renseigné', rawValue: apartment.googleMapsLink, compact: true } %}
                    </div>
                </section>

                <section class="admin-detail-focus-card">
                    <div class="admin-detail-focus-head">
                        <div>
                            <span class="admin-detail-focus-kicker">Ouverture</span>
                            <h3>Codes et consignes</h3>
                        </div>
                    </div>
                    <div class="info-list admin-detail-info-group">
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'buildingAccessCode', label: 'Code immeuble', value: apartment.buildingAccessCode ?: 'Non renseigné', rawValue: apartment.buildingAccessCode, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'keyBoxCode', label: 'Code boîte à clés / code porte', value: apartment.keyBoxCode ?: 'Non renseigné', rawValue: apartment.keyBoxCode, compact: true } %}
                        {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'entryInstructions', label: 'Consignes d’entrée', value: apartment.entryInstructions ?: 'Aucune consigne', rawValue: apartment.entryInstructions, multiline: true } %}
                    </div>
                </section>
            </div>

            <section class="admin-detail-focus-card">
                <div class="admin-detail-focus-head">
                    <div>
                        <span class="admin-detail-focus-kicker">Contact</span>
                        <h3>Propriétaire et notes internes</h3>
                    </div>
                </div>
                <div class="info-list admin-detail-info-group">
                    {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'ownerName', label: 'Nom du propriétaire', value: apartment.ownerName ?: 'Non renseigné', rawValue: apartment.ownerName } %}
                    {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'ownerPhone', label: 'Téléphone', value: apartment.ownerPhone ?: 'Non renseigné', rawValue: apartment.ownerPhone } %}
                    {% include 'admin/_editable_apartment_field.html.twig' with { apartment: apartment, field: 'internalNotes', label: 'Notes internes', value: apartment.internalNotes ?: 'Aucune note', rawValue: apartment.internalNotes, multiline: true } %}
                </div>
            </section>
        </div>

        <div id="apartment-panel-assignment" class="panel span-two admin-detail-panel is-collapsed" data-panel-group="apartment-admin" data-panel-name="assignment">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Équipe</span>
                    <h2>Assignation et priorité</h2>
                    <p>Décide qui voit l’appartement côté terrain et s’il doit remonter en haut de la liste.</p>
                </div>
                <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-assignment">Retour</button>
            </div>
            <div class="admin-dual-stack">
                <form method="post" action="{{ path('admin_apartment_assign', {id: apartment.id}) }}" class="stack-form employee-home-info-card employee-home-info-card-soft admin-assignment-form-card" data-async-form data-update-target="#apartment-detail-root">
                    <label>
                        <span>Employés assignés</span>
                        <select name="assignedEmployees[]" multiple size="5">
                            {% for employee in employees %}
                                {% if 'ROLE_ADMIN' not in employee.roles %}
                                    <option value="{{ employee.id }}" {{ apartment.assignedEmployees.contains(employee) ? 'selected' : '' }}>{{ employee.fullName }} - {{ employee.email }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </label>
                    <button class="secondary-button admin-dark-button" type="submit">Mettre à jour l’assignation</button>
                </form>

                <form method="post" action="{{ path('admin_apartment_priority', {id: apartment.id}) }}" class="stack-form employee-home-primary-card" data-async-form data-update-target="#apartment-detail-root">
                    <div class="employee-home-primary-content">
                        <span class="employee-home-kicker">Priorité</span>
                        <h2>Faire ressortir cet appartement</h2>
                        <p>Place cet appartement dans les priorités employé et fixe une date d’inventaire.</p>
                    </div>
                    <label class="checkbox-row">
                        <input type="checkbox" name="isInventoryPriority" value="1" {{ apartment.isInventoryPriority ? 'checked' : '' }}>
                        <span>Faire apparaître en priorité chez l’employé</span>
                    </label>
                    <label>
                        <span>Date d’inventaire</span>
                        <input type="datetime-local" name="inventoryDueAt" value="{{ apartment.inventoryDueAt ? apartment.inventoryDueAt|date('Y-m-d\\TH:i') : '' }}">
                    </label>
                    <button class="secondary-button admin-dark-button admin-inverted-button" type="submit">Enregistrer la priorité</button>
                </form>
            </div>
        </div>

        <div id="apartment-panel-rooms" class="panel span-two admin-detail-panel is-collapsed" data-panel-group="apartment-admin" data-panel-name="rooms">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Structure</span>
                    <h2>Pièces et équipements</h2>
                    <p>Construis la structure de l’appartement avec des ajouts rapides puis enrichis chaque pièce.</p>
                </div>
                <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-rooms">Retour</button>
            </div>

            <section class="admin-detail-focus-card">
                <div class="admin-detail-focus-head">
                    <div>
                        <span class="admin-detail-focus-kicker">Ajout rapide</span>
                        <h3>Commencer par les pièces principales</h3>
                    </div>
                    <span class="status-badge is-soft">{{ apartment.activeRooms|length }} pièce{{ apartment.activeRooms|length > 1 ? 's' : '' }}</span>
                </div>

                <div class="quick-actions admin-quick-actions">
                    {% for roomType in roomTypes %}
                        <form method="post" action="{{ path('admin_room_create', {id: apartment.id}) }}" data-async-form data-update-target="#apartment-detail-root">
                            <input type="hidden" name="type" value="{{ roomType.value }}">
                            <input type="hidden" name="name" value="{{ roomType.label }}">
                            <button class="chip-button" type="submit">Ajouter {{ roomType.label|lower }}</button>
                        </form>
                    {% endfor %}
                </div>
            </section>

            <div class="room-stack">
                {% for room in apartment.activeRooms %}
                    <article class="room-card">
                        <div class="room-card-head">
                            <div>
                                <h3>{{ room.name }}</h3>
                                <p>{{ room.type.label }} · {{ room.activeRoomEquipments|length }} équipements</p>
                            </div>
                            {% if room.activeRoomEquipments|length == 0 %}
                                <form
                                    method="post"
                                    action="{{ path('admin_room_delete', {id: room.id}) }}"
                                    data-async-form
                                    data-update-target="#apartment-detail-root"
                                    data-confirm-reset
                                    data-confirm-title="Supprimer la pièce"
                                    data-confirm-message="Veux-tu vraiment supprimer cette pièce vide ?"
                                >
                                    <button class="icon-action-button icon-action-button-danger" type="submit" aria-label="Supprimer la pièce {{ room.name }}" title="Supprimer la pièce">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M7 5h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            <path d="M10 5V4h4v1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            <path d="M9 9v7M12 9v7M15 9v7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                            <path d="M8 7h8l-.6 11.2a2 2 0 0 1-2 1.8h-2.8a2 2 0 0 1-2-1.8L8 7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
                                        </svg>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                        <div class="equipment-tags">
                            {% for equipment in room.activeRoomEquipments %}
                                <form
                                    method="post"
                                    action="{{ path('admin_room_equipment_delete', {id: equipment.id}) }}"
                                    class="equipment-tag equipment-tag-form"
                                    data-async-form
                                    data-update-target="#apartment-detail-root"
                                    data-confirm-reset
                                    data-confirm-title="Supprimer l’équipement"
                                    data-confirm-message="Veux-tu vraiment supprimer cet équipement de la pièce ?"
                                >
                                    <span>{{ equipment.label }}</span>
                                    <button class="equipment-tag-remove" type="submit" aria-label="Supprimer {{ equipment.label }}" title="Supprimer {{ equipment.label }}">×</button>
                                </form>
                            {% else %}
                                <span class="empty-inline">Aucun équipement ajouté.</span>
                            {% endfor %}
                        </div>
                        <form method="post" action="{{ path('admin_room_equipment_add', {id: room.id}) }}" class="inline-form" data-async-form data-update-target="#apartment-detail-root">
                            <select name="catalogEquipmentId">
                                <option value="">Choisir un équipement catalogue</option>
                                {% for item in catalog %}
                                    {% if item.roomType.value == room.type.value %}
                                        <option value="{{ item.id }}">{{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <input type="text" name="manualLabel" placeholder="Ou ajouter un équipement manuel">
                            <button class="secondary-button" type="submit">Ajouter</button>
                        </form>
                    </article>
                {% else %}
                    <p class="empty-state">Commence par ajouter les pièces principales de l’appartement.</p>
                {% endfor %}
            </div>
        </div>

        <div id="apartment-panel-anomalies" class="panel span-two admin-detail-panel is-collapsed" data-panel-group="apartment-admin" data-panel-name="anomalies">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Suivi</span>
                    <h2>Anomalies ouvertes</h2>
                    <p>Identifie les pièces touchées puis ouvre le détail complet pour traiter le suivi.</p>
                </div>
                <div class="admin-detail-panel-actions">
                    <a class="secondary-button" href="{{ path('admin_apartment_anomalies', {id: apartment.id}) }}">Ouvrir la vue anomalies</a>
                    <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-anomalies">Retour</button>
                </div>
            </div>

            {% if anomalyCount > 0 %}
                <div class="anomaly-room-grid">
                    {% for group in anomalyGroups %}
                        <a class="compact-card room-anomaly-card" href="{{ path('admin_apartment_anomalies', {id: apartment.id}) }}#room-{{ group.room.id }}">
                            <strong>{{ group.room.name }}</strong>
                            <p>{{ group.room.type.label }}</p>
                            <span class="status-badge is-warning">{{ group.count }} anomalie{{ group.count > 1 ? 's' : '' }}</span>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="empty-state">Aucune anomalie sur cet appartement.</p>
            {% endif %}
        </div>

        <div id="apartment-panel-settings" class="panel span-two admin-detail-panel is-collapsed" data-panel-group="apartment-admin" data-panel-name="settings">
            <div class="admin-detail-panel-head">
                <div>
                    <span class="admin-detail-entry-kicker">Pilotage</span>
                    <h2>Statut et archivage</h2>
                    <p>Utilise cette zone seulement pour changer le statut global de l’appartement ou le retirer du circuit.</p>
                </div>
                <button class="secondary-button admin-detail-back-button" type="button" data-panel-close="#apartment-panel-settings">Retour</button>
            </div>
            <div class="panel-head">
                <h3>Statut actuel</h3>
                <span class="status-badge">{{ apartment.status.label }}</span>
            </div>
            <div class="card-action-row">
                <form method="post" action="{{ path('admin_apartment_status', {id: apartment.id}) }}" data-async-form data-update-target="#apartment-detail-root">
                    <input type="hidden" name="status" value="active">
                    <button class="secondary-button" type="submit">Mettre en actif</button>
                </form>
                <form method="post" action="{{ path('admin_apartment_status', {id: apartment.id}) }}" data-async-form data-update-target="#apartment-detail-root">
                    <input type="hidden" name="status" value="inactive">
                    <button class="secondary-button" type="submit">Mettre en inactif</button>
                </form>
                <form method="post" action="{{ path('admin_apartment_status', {id: apartment.id}) }}" data-async-form data-update-target="#apartment-detail-root">
                    <input type="hidden" name="status" value="archived">
                    <button class="secondary-button" type="submit">Archiver</button>
                </form>
                {% if canDeleteApartment %}
                    <form
                        method="post"
                        action="{{ path('admin_apartment_delete', {id: apartment.id}) }}"
                        data-async-form
                        data-confirm-reset
                        data-confirm-title="Supprimer l’appartement"
                        data-confirm-message="Veux-tu vraiment supprimer cet appartement ? Cette action est définitive."
                    >
                        <button class="secondary-button danger-button" type="submit">Supprimer</button>
                    </form>
                {% else %}
                    <div class="empty-state">
                        La suppression n’est autorisée que s’il n’y a plus de check-out en cours ou programmé, ni d’anomalie ouverte.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
