{% extends 'base.html.twig' %}

{% block title %}Appartements{% endblock %}

{% block body %}
    <section class="admin-home-intro admin-home-intro-page">
        <div>
            <h1>Appartements</h1>
        </div>
    </section>

    <section class="admin-apartments-layout">
        <div class="panel admin-form-panel">
            
            <button
                class="primary-button admin-create-toggle-button"
                type="button"
                data-toggle-target="#admin-apartment-create-form"
                data-toggle-label-closed="Ajouter"
                data-toggle-label-open="Masquer le formulaire"
            >
                Ajouter
            </button>
            <form id="admin-apartment-create-form" method="post" action="{{ path('admin_apartment_create') }}" class="stack-form tight-form admin-create-form is-collapsed">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_apartment_create') }}">
                <label><span>Nom *</span><input name="name" required data-apartment-template-name></label>
                <button
                    class="secondary-button apartment-template-toggle-button"
                    type="button"
                    data-toggle-target="#admin-apartment-template-fields"
                    data-toggle-label-closed="À partir d’un modèle"
                    data-toggle-label-open="Revenir à une création vide"
                >
                    À partir d’un modèle
                </button>
                <div id="admin-apartment-template-fields" class="admin-apartment-template-fields is-collapsed" hidden>
                    <p class="muted">Renseigne d’abord le nom de l’appartement, puis choisis le logement existant à dupliquer.</p>
                    <label>
                        <span>Appartement modèle</span>
                        <select name="templateApartmentId" data-apartment-template-select disabled>
                            <option value="">Choisir un appartement existant</option>
                            {% for templateApartment in apartmentTemplates %}
                                <option value="{{ templateApartment.id }}">{{ templateApartment.name }} - {{ templateApartment.city }}</option>
                            {% endfor %}
                        </select>
                    </label>
                </div>
                <label><span>Adresse *</span><input name="addressLine1"></label>
                <label><span>Complément</span><input name="addressLine2"></label>
                <div class="grid-two">
                    <label><span>Ville *</span><input name="city"></label>
                    <label><span>Code postal</span><input name="postalCode"></label>
                </div>
                <div class="grid-two">
                    <label><span>Étage</span><input name="floor"></label>
                    <label><span>Porte</span><input name="doorNumber"></label>
                </div>
                <label><span>Numéro de boîte aux lettres</span><input name="mailboxNumber"></label>
                <label><span>Lien Google Maps</span><input name="googleMapsLink"></label>
                <div class="grid-two">
                    <label><span>Code immeuble</span><input name="buildingAccessCode"></label>
                    <label><span>Code boîte à clés / code porte</span><input name="keyBoxCode"></label>
                </div>
                <label><span>Instructions d’entrée</span></label>
                <div class="trix-field-shell">
                    <input id="apartment-create-entry-instructions" type="hidden" name="entryInstructions" value="">
                    <trix-editor input="apartment-create-entry-instructions" class="trix-content apartment-trix-editor"></trix-editor>
                </div>
                <div class="grid-two">
                    <label><span>État *</span>
                        <select name="conditionStatus">
                            <option value="Très bon état">Très bon état</option>
                            <option value="Bon état" selected>Bon état</option>
                            <option value="Correct">Correct</option>
                            <option value="À surveiller">À surveiller</option>
                            <option value="En maintenance">En maintenance</option>
                        </select>
                    </label>
                    <label><span>Statut *</span>
                        <select name="status">
                            {% for item in apartmentStatuses %}
                                <option value="{{ item.value }}">{{ item.label }}</option>
                            {% endfor %}
                        </select>
                    </label>
                </div>
                <div class="grid-two">
                    <label><span>Nombre de chambres *</span><input type="number" name="bedroomCount" min="0" value="1"></label>
                </div>
                <div class="grid-two">
                    <label><span>Nom du propriétaire *</span><input name="ownerName"></label>
                    <label><span>Numéro de téléphone *</span><input name="ownerPhone"></label>
                </div>
                <label><span>Notes internes</span></label>
                <div class="trix-field-shell">
                    <input id="apartment-create-internal-notes" type="hidden" name="internalNotes" value="">
                    <trix-editor input="apartment-create-internal-notes" class="trix-content apartment-trix-editor"></trix-editor>
                </div>
                <label class="checkbox-row">
                    <input type="checkbox" name="isInventoryPriority" value="1">
                    <span>Faire remonter dans la liste employé</span>
                </label>
                <label><span>Inventaire prévu pour</span><input type="datetime-local" name="inventoryDueAt"></label>
                <label><span>Assigner à</span>
                    <select name="assignedEmployees[]" multiple size="4">
                        {% for employee in employees %}
                            {% if 'ROLE_ADMIN' not in employee.roles %}
                                <option value="{{ employee.id }}">{{ employee.fullName }} - {{ employee.email }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </label>
                <button class="primary-button" type="submit">Créer l’appartement</button>
            </form>
        </div>

        {% include 'admin/_apartments_list.html.twig' %}
    </section>
{% endblock %}

