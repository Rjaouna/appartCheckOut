<div id="admin-arrivals-root">
    <section class="page-head employee-page-head">
        <div>
            <h1>Gestion des arrivées</h1>
            <p>{{ reservations|length }} réservation{{ reservations|length > 1 ? 's' : '' }} active{{ reservations|length > 1 ? 's' : '' }} à suivre, avec les actions terrain et admin.</p>
        </div>
        <div class="head-actions">
            <a class="secondary-button" href="{{ path('admin_arrivals_history') }}">Historique des arrivées</a>
            <a class="secondary-button app-back-button" href="{{ path('admin_dashboard') }}">Retour</a>
        </div>
    </section>

    <section class="employee-arrival-stack admin-arrival-pro-stack">
        {% for reservation in reservations %}
            {% set apartment = reservation.apartment %}
            {% set activeManagers = apartment.assignedEmployees|filter(employee => 'ROLE_ADMIN' not in employee.roles) %}
            {% set leadManager = activeManagers|first %}
            {% set extraManagers = activeManagers|slice(1) %}
            {% set managerListId = 'arrival-page-managers-' ~ reservation.id %}
            {% set isToday = reservation.isArrivalToday(todayDate) %}
            {% set isFuture = reservation.isArrivalInFuture(todayDate) %}
            {% set isActiveStay = reservation.arrivalDate and reservation.departureDate and reservation.arrivalDate <= todayDate and reservation.departureDate >= todayDate %}
            {% set shouldDiscourageSend = isFuture %}
            {% set canSendAccess = reservation.guestWhatsappNumber is not empty %}
            {% set whatsappNumber = reservation.guestWhatsappNumber|replace({'+': '', ' ': '', '-': '', '.': '', '(': '', ')': ''}) %}
            {% set accessCode = apartment.keyBoxCode ?: apartment.buildingAccessCode %}

            <article class="employee-arrival-pro-card admin-arrival-pro-card {{ isToday ? 'is-today' : '' }} {{ isFuture ? 'is-future' : '' }}">
                <div class="employee-arrival-pro-top">
                    <div>
                        <span class="employee-home-kicker">{{ isToday ? 'Arrivée aujourd’hui' : (isFuture ? 'Arrivée à venir' : 'Séjour en cours') }}</span>
                        <h2>{{ reservation.guestName }}</h2>
                        <p>
                            <a class="card-title-link" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">{{ apartment.name }}</a>
                            · {{ reservation.stayDateLabel }}
                        </p>
                    </div>
                    <span class="status-badge {{ reservation.hasSentAccessMessage ? 'is-success' : (isToday ? 'is-warning' : 'is-soft') }}">
                        {% if reservation.hasSentAccessMessage %}
                            Accès envoyés
                        {% elseif isToday %}
                            À envoyer
                        {% elseif isFuture %}
                            À préparer
                        {% else %}
                            À vérifier
                        {% endif %}
                    </span>
                </div>

                <div class="employee-arrival-info-grid">
                    <div class="employee-arrival-info-card employee-arrival-info-card-wide">
                        <span>Adresse</span>
                        {% if apartment.wazeLink %}
                            <a href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">{{ apartment.fullAddress }}</a>
                        {% else %}
                            <strong>{{ apartment.fullAddress }}</strong>
                        {% endif %}
                    </div>
                    <div class="employee-arrival-info-card">
                        <span>Arrivée</span>
                        <strong>{{ reservation.arrivalDate ? reservation.arrivalDate|date('d/m/Y') : '-' }}</strong>
                    </div>
                    <div class="employee-arrival-info-card">
                        <span>Départ</span>
                        <strong>{{ reservation.departureDate ? reservation.departureDate|date('d/m/Y') : '-' }}</strong>
                    </div>
                    <div class="employee-arrival-info-card">
                        <span>Accès logement</span>
                        <strong>{{ accessCode ?: 'Non renseigné' }}</strong>
                    </div>
                    <div class="employee-arrival-info-card">
                        <span>Message client</span>
                        <strong>
                            {% if reservation.hasSentAccessMessage %}
                                Envoyé {{ reservation.accessMessageSentAt ? reservation.accessMessageSentAt|date('d/m à H:i') : '' }}
                            {% elseif canSendAccess %}
                                Prêt à envoyer
                            {% else %}
                                Numéro manquant
                            {% endif %}
                        </strong>
                    </div>
                    <div class="employee-arrival-info-card employee-arrival-info-card-wide">
                        <span>Gérant</span>
                        {% if leadManager %}
                            <strong class="admin-arrival-manager-inline">
                                <a class="apartment-manager-link" href="{{ path('admin_user_show', {id: leadManager.id}) }}">{{ leadManager.fullName }}</a>
                                {% if leadManager.phoneNumber %}
                                    <a class="inline-phone-link" href="tel:{{ leadManager.phoneNumber }}" aria-label="Appeler {{ leadManager.fullName }}">✆</a>
                                {% endif %}
                            </strong>
                            {% if extraManagers|length > 0 %}
                                <button
                                    class="apartment-manager-toggle"
                                    type="button"
                                    data-toggle-target="#{{ managerListId }}"
                                    data-toggle-label-open="(+{{ extraManagers|length }} autres)"
                                    data-toggle-label-closed="(+{{ extraManagers|length }} autres)"
                                >
                                    (+{{ extraManagers|length }} autres)
                                </button>
                            {% endif %}
                        {% else %}
                            <strong>Aucun gérant assigné</strong>
                        {% endif %}

                        {% if extraManagers|length > 0 %}
                            <div id="{{ managerListId }}" class="apartment-manager-list is-collapsed">
                                {% for employee in extraManagers %}
                                    <span class="admin-arrival-manager-inline">
                                        <a class="apartment-manager-link" href="{{ path('admin_user_show', {id: employee.id}) }}">{{ employee.fullName }}</a>
                                        {% if employee.phoneNumber %}
                                            <a class="inline-phone-link" href="tel:{{ employee.phoneNumber }}" aria-label="Appeler {{ employee.fullName }}">✆</a>
                                        {% endif %}
                                    </span>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="admin-arrival-edit-panel">
                    <span class="employee-home-kicker">Actions admin</span>
                    <div class="admin-arrival-edit-grid">
                        {% include 'admin/_editable_reservation_field.html.twig' with {
                            reservation: reservation,
                            field: 'guestName',
                            label: 'Locataire',
                            value: reservation.guestName,
                            rawValue: reservation.guestName,
                            context: 'arrivals',
                            updateTarget: '#admin-arrivals-root',
                            swapMode: 'outer'
                        } %}

                        {% include 'admin/_editable_reservation_field.html.twig' with {
                            reservation: reservation,
                            field: 'guestWhatsappNumber',
                            label: 'WhatsApp',
                            value: reservation.guestWhatsappNumber,
                            rawValue: reservation.guestWhatsappNumber,
                            context: 'arrivals',
                            updateTarget: '#admin-arrivals-root',
                            swapMode: 'outer'
                        } %}
                    </div>
                </div>

                <div class="employee-arrival-action-grid admin-arrival-action-grid">
                    {% if apartment.wazeLink %}
                        <a class="employee-arrival-action employee-arrival-action-waze" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">
                            <span>Y aller avec Waze</span>
                        </a>
                    {% endif %}

                    {% if canSendAccess %}
                        <form
                            method="post"
                            action="{{ path('admin_reservation_send_access', {id: reservation.id}) }}"
                            data-async-form
                            data-update-target="#admin-arrivals-root"
                            data-swap-mode="outer"
                            {% if shouldDiscourageSend %}
                                data-confirm-reset
                                data-confirm-title="Envoyer avant l’arrivée"
                                data-confirm-message="L’arrivée n’est pas prévue aujourd’hui. Veux-tu envoyer les informations quand même ?"
                            {% endif %}
                        >
                            <input type="hidden" name="context" value="arrivals">
                            <button class="{{ reservation.hasSentAccessMessage ? 'secondary-button' : 'primary-button' }} full-width" type="submit">
                                {{ reservation.hasSentAccessMessage ? 'Renvoyer les accès' : 'Envoyer les accès' }}
                            </button>
                        </form>

                        <a class="secondary-button full-width" href="https://wa.me/{{ whatsappNumber }}" target="_blank" rel="noreferrer">
                            Contacter le locataire
                        </a>
                    {% else %}
                        <button class="secondary-button full-width" type="button" disabled>Numéro WhatsApp manquant</button>
                    {% endif %}

                    {% if isActiveStay %}
                        <a class="primary-button full-width" href="{{ path('admin_checkin_form', {id: reservation.id}) }}">Faire le check-in</a>
                    {% else %}
                        <button class="secondary-button full-width" type="button" disabled>
                            Check-in disponible le {{ reservation.arrivalDate ? reservation.arrivalDate|date('d/m/Y') : 'jour d’arrivée' }}
                        </button>
                    {% endif %}

                    <a class="secondary-button full-width" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">Voir l’appartement</a>

                    <form
                        method="post"
                        action="{{ path('admin_reservation_delete', {id: reservation.id}) }}"
                        data-async-form
                        data-update-target="#admin-arrivals-root"
                        data-swap-mode="outer"
                        data-confirm-reset
                        data-confirm-title="Annuler la réservation"
                        data-confirm-message="Cette réservation sera supprimée définitivement. Continuer ?"
                    >
                        <input type="hidden" name="context" value="arrivals">
                        <button class="secondary-button danger-button full-width" type="submit">Annuler la réservation</button>
                    </form>
                </div>
            </article>
        {% else %}
            <p class="empty-state">Aucune arrivée locataire n’est enregistrée pour le moment.</p>
        {% endfor %}
    </section>
</div>
