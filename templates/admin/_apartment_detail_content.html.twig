{% if currentSection is not defined or currentSection is null %}
    <section class="page-head apartment-hero">
        <div class="apartment-hero-main">
            <div class="apartment-hero-copy">
                <span class="eyebrow apartment-hero-eyebrow">Appartement · {{ apartment.name }}</span>
                <div class="apartment-hero-title-row">
                    <h1>
                        <button
                            class="apartment-hero-name-link"
                            type="button"
                            aria-label="Modifier le nom de l’appartement"
                            title="Modifier le nom de l’appartement"
                            data-apartment-name-modal-trigger
                        >
                            {{ apartment.name }}
                        </button>
                    </h1>
                </div>
                <div class="apartment-hero-address-card">
                    <div class="apartment-hero-address-copy">
                        <span class="apartment-hero-address-label">Adresse complète</span>
                        <p>
                            <a class="address-link apartment-hero-address-link" href="{{ apartment.wazeLink }}" target="_blank" rel="noreferrer">
                                {{ apartment.fullAddress }}
                            </a>
                        </p>
                    </div>
                    <div class="apartment-hero-meta-list">
                        {% set assignedEmployees = apartment.assignedEmployees|default([]) %}
                        {% set leadEmployee = assignedEmployees|length > 0 ? assignedEmployees|first : null %}
                        {% set extraManagers = assignedEmployees|length > 1 ? assignedEmployees|slice(1) : [] %}

                        <div class="apartment-hero-meta-item">
                            <span class="apartment-hero-address-label">Gérant</span>
                            {% if leadEmployee %}
                                <div class="apartment-hero-manager-block">
                                    <a class="apartment-hero-manager-link" href="{{ path('admin_user_show', {id: leadEmployee.id}) }}">
                                        {{ leadEmployee.fullName }}
                                    </a>
                                    {% if extraManagers|length > 0 %}
                                        <button
                                            class="apartment-hero-manager-more"
                                            type="button"
                                            data-manager-list-toggle
                                            data-target="#apartment-manager-list"
                                            aria-expanded="false"
                                        >
                                            (+{{ extraManagers|length }} autre{{ extraManagers|length > 1 ? 's' : '' }})
                                        </button>
                                    {% endif %}
                                </div>
                                {% if extraManagers|length > 0 %}
                                    <div id="apartment-manager-list" class="apartment-hero-manager-list is-collapsed" hidden>
                                        {% for employee in extraManagers %}
                                            <a href="{{ path('admin_user_show', {id: employee.id}) }}">{{ employee.fullName }}</a>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            {% else %}
                                <span class="muted">Aucun gérant assigné</span>
                            {% endif %}
                        </div>

                        <div class="apartment-hero-meta-item">
                            <span class="apartment-hero-address-label">Code de la porte</span>
                            <strong>{{ apartment.keyBoxCode ?: 'Non renseigné' }}</strong>
                        </div>

                        <div class="apartment-hero-meta-item">
                            <span class="apartment-hero-address-label">Accès locataire</span>
                            <strong>{{ apartment.isTenantAccessEnabled ? 'Actif' : 'Bloqué' }}</strong>
                        </div>

                        <div class="apartment-hero-meta-item">
                            <a class="apartment-hero-anomaly-link" href="{{ path('admin_apartment_anomalies', {id: apartment.id}) }}">
                                {{ anomalyCount }} anomal{{ anomalyCount > 1 ? 'ies' : 'ie' }} sur ce logement
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="head-actions apartment-hero-actions">
                <form
                    method="post"
                    action="{{ path('admin_apartment_tenant_access', {id: apartment.id}) }}"
                    class="apartment-hero-priority-form"
                    data-async-form
                    data-update-target="{{ detailUpdateTarget|default('#apartment-detail-root') }}"
                >
                    {% if currentSection is defined and currentSection %}
                        <input type="hidden" name="section" value="{{ currentSection }}">
                    {% endif %}
                    <input type="hidden" name="isTenantAccessEnabled" value="{{ apartment.isTenantAccessEnabled ? '0' : '1' }}">
                    <button class="{{ apartment.isTenantAccessEnabled ? 'secondary-button danger-button' : 'primary-button' }} apartment-hero-priority-button" type="submit">
                        {{ apartment.isTenantAccessEnabled ? 'Bloquer l’accès locataire' : 'Réactiver l’accès locataire' }}
                    </button>
                </form>
                <form
                    method="post"
                    action="{{ path('admin_apartment_priority', {id: apartment.id}) }}"
                    class="apartment-hero-priority-form"
                    data-async-form
                    data-update-target="{{ detailUpdateTarget|default('#apartment-detail-root') }}"
                >
                    {% if currentSection is defined and currentSection %}
                        <input type="hidden" name="section" value="{{ currentSection }}">
                    {% endif %}
                    <input type="hidden" name="isInventoryPriority" value="{{ apartment.isInventoryPriority ? '0' : '1' }}">
                    <button class="{{ apartment.isInventoryPriority ? 'secondary-button' : 'primary-button' }} apartment-hero-priority-button" type="submit">
                        {{ apartment.isInventoryPriority ? 'Retirer la priorité' : 'Mettre en priorité' }}
                    </button>
                </form>
                <a class="secondary-button apartment-hero-action" href="{{ path('admin_apartments') }}">Retour à la liste</a>
            </div>
        </div>
    </section>

    <div class="modal fade" id="apartmentNameModal" tabindex="-1" aria-labelledby="apartmentNameModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content apartment-name-modal-content">
                <div class="modal-header apartment-name-modal-header">
                    <div>
                        <span class="eyebrow">Appartement</span>
                        <h4 class="modal-title" id="apartmentNameModalLabel">Modifier le nom</h4>
                    </div>
                    <button type="button" class="btn-close" aria-label="Fermer" data-modal-close></button>
                </div>
                <form
                    method="post"
                    action="{{ path('admin_apartment_name_update', {id: apartment.id}) }}"
                    class="stack-form apartment-name-modal-form"
                    data-async-form
                    data-update-target="{{ detailUpdateTarget|default('#apartment-detail-root') }}"
                    data-close-modal="apartmentNameModal"
                >
                    {% if currentSection is defined and currentSection %}
                        <input type="hidden" name="section" value="{{ currentSection }}">
                    {% endif %}
                    <label>
                        <span>Nouveau nom</span>
                        <input type="text" name="name" value="{{ apartment.name }}" required data-apartment-name-modal-input>
                    </label>
                    <div class="editable-field-actions">
                        <button class="primary-button" type="submit">Enregistrer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endif %}

<section id="apartment-structure">
    {% include 'admin/_apartment_structure.html.twig' %}
</section>
