{% set launchableApartmentCards = apartmentCards|filter(card => card.canLaunchCheckout) %}
{% set launchableCheckoutCount = launchableApartmentCards|length %}
{% set pendingCheckoutCount = scheduledCheckouts|length %}

<div class="admin-dashboard-hub">
    <section class="admin-dashboard-hero">
        <div class="admin-dashboard-hero-copy">
            <h1>Espace admin</h1>
            <p>Tout le nécessaire pour gérer les appartements, les anomalies et les check-outs.</p>
        </div>
        <div class="admin-dashboard-hero-actions">
            <a class="primary-button" href="{{ path('admin_apartments') }}">Ajouter un appartement</a>
            {% if launchableCheckoutCount == 0 %}
                <button class="secondary-button admin-dashboard-hero-secondary is-disabled" type="button" disabled>
                    Aucun appartement à programmer
                </button>
            {% else %}
                <button
                    class="secondary-button admin-dashboard-hero-secondary"
                    type="button"
                    data-action-menu-trigger
                    data-action-menu-title="Programmer un check-out"
                    data-action-menu-source="#dashboard-launch-checkout-menu"
                >
                    Lancer un check-out
                </button>
            {% endif %}
        </div>
    </section>

    <section class="admin-dashboard-entry-grid">
        <article class="admin-dashboard-entry-card admin-dashboard-entry-card-primary" data-click-url="{{ path('admin_apartments') }}">
            <div class="admin-dashboard-entry-top">
                <span class="admin-dashboard-entry-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3v-10.5Z" fill="currentColor"/>
                    </svg>
                </span>
                <span class="admin-dashboard-entry-count">{{ apartmentCards|length }}</span>
            </div>
            <div class="admin-dashboard-entry-copy">
                <h2><a class="admin-dashboard-title-link" href="{{ path('admin_apartments') }}">Appartements</a></h2>
                <p>{{ apartmentCards|length > 0 ? 'Liste complète et accès rapide aux fiches.' : 'Aucun appartement actif.' }}</p>
            </div>
        </article>

        <article class="admin-dashboard-entry-card admin-dashboard-entry-card-warning" data-click-url="{{ path('admin_anomalies') }}">
            <div class="admin-dashboard-entry-top">
                <span class="admin-dashboard-entry-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2 1 21h22L12 2Zm1 14h-2v-2h2v2Zm0-4h-2V8h2v4Z" fill="currentColor"/>
                    </svg>
                </span>
                <span class="admin-dashboard-entry-count">{{ anomalyApartmentCards|length }}</span>
            </div>
            <div class="admin-dashboard-entry-copy">
                <h2><a class="admin-dashboard-title-link" href="{{ path('admin_anomalies') }}">Appartements avec anomalies</a></h2>
                <p>
                    {% if anomalyApartmentCards|length > 0 %}
                        Accès direct aux appartements à surveiller.
                    {% else %}
                        Aucune anomalie ouverte.
                    {% endif %}
                </p>
            </div>
        </article>
    </section>

    <section class="admin-dashboard-stack">
        <article class="admin-dashboard-wide-card admin-dashboard-wide-card-soft" data-click-url="{{ path('admin_users') }}">
            <div class="admin-dashboard-wide-copy">
                <div class="admin-dashboard-wide-topline">
                    <span class="admin-dashboard-entry-icon admin-dashboard-entry-icon-soft" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4ZM8 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm8 2c-2.67 0-8 1.34-8 4v3h16v-3c0-2.66-5.33-4-8-4ZM8 13c-.29 0-.62.02-.97.05C4.42 13.27 0 14.44 0 17v3h6v-3c0-1.16.55-2.18 1.53-3A8.63 8.63 0 0 1 8 13Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-dashboard-wide-badge">{{ employeeCount }} employé{{ employeeCount > 1 ? 's' : '' }}</span>
                </div>
                <h2><a class="admin-dashboard-title-link" href="{{ path('admin_users') }}">Gérer les employés</a></h2>
                <p>Créer, modifier et autoriser le suivi des anomalies.</p>
            </div>
        </article>

        <article class="admin-dashboard-wide-card admin-dashboard-wide-card-accent">
            <div class="admin-dashboard-wide-copy">
                <div class="admin-dashboard-wide-topline">
                    <span class="admin-dashboard-entry-icon admin-dashboard-entry-icon-accent" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M19 11h-6V5h-2v6H5v2h6v6h2v-6h6v-2Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span class="admin-dashboard-wide-badge">{{ pendingCheckoutCount }} en attente</span>
                </div>
                <h2>Check-outs à traiter</h2>
                <p>Ouvre directement un check-out en attente pour démarrer l’inventaire.</p>
                <div class="admin-dashboard-chip-row admin-dashboard-chip-row-start">
                    <span class="admin-dashboard-chip">{{ scheduledCheckouts|length }} en attente</span>
                    <span class="admin-dashboard-chip">{{ activeCheckouts|length }} en cours</span>
                    <span class="admin-dashboard-chip">{{ finishedCheckouts|length }} terminés</span>
                </div>
            </div>

            <div class="admin-dashboard-wide-actions">
                {% if pendingCheckoutCount == 0 %}
                    <button class="primary-button is-disabled" type="button" disabled>Aucun check-out en attente</button>
                {% else %}
                    <button
                        class="primary-button"
                        type="button"
                        data-action-menu-trigger
                        data-action-menu-title="Check-outs en attente"
                        data-action-menu-source="#dashboard-checkout-status-menu"
                    >
                        Ouvrir les check-outs
                    </button>
                {% endif %}
                <span class="admin-dashboard-inline-note">{{ pendingCheckoutCount }} check-out{{ pendingCheckoutCount > 1 ? 's' : '' }} prêt{{ pendingCheckoutCount > 1 ? 's' : '' }} à démarrer</span>
            </div>
        </article>
    </section>

    <div id="dashboard-launch-checkout-menu" class="workflow-actions-source" hidden>
        <div class="action-menu-grid">
            {% for card in launchableApartmentCards %}
                <div class="admin-dashboard-launch-tile">
                    <div class="admin-dashboard-launch-head">
                        <span class="action-menu-icon action-menu-icon-pink" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3v-10.5Z" fill="currentColor"/>
                            </svg>
                        </span>
                        <div class="admin-dashboard-launch-copy">
                            <strong>{{ card.apartment.name }}</strong>
                            <small>{{ card.assignedEmployeeNames }}</small>
                        </div>
                    </div>

                    {% if card.assignedEmployees is not empty %}
                        <form method="post" action="{{ path('admin_checkout_create', {id: card.apartment.id}) }}" class="admin-dashboard-launch-form" data-async-form data-update-target="#admin-dashboard-content">
                            <input type="hidden" name="priority" value="normal">
                            <input type="hidden" name="context" value="dashboard">
                            {% if card.assignedEmployees|length == 1 %}
                                <input type="hidden" name="assignedTo" value="{{ card.firstAssignedEmployeeId }}">
                            {% else %}
                                <label class="admin-dashboard-launch-field">
                                    <span>Employé</span>
                                    <select name="assignedTo" required>
                                        {% for employee in card.assignedEmployees %}
                                            <option value="{{ employee.id }}">{{ employee.fullName }}</option>
                                        {% endfor %}
                                    </select>
                                </label>
                            {% endif %}
                            <button class="primary-button" type="submit">Programmer le check-out</button>
                        </form>
                    {% else %}
                        <div class="admin-dashboard-launch-empty">
                            <span class="admin-dashboard-inline-note">Assigne d’abord un employé à cet appartement.</span>
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="action-menu-tile action-menu-tile-muted">
                    <span class="action-menu-icon action-menu-icon-dark">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span>Aucun appartement disponible</span>
                    <small>Assigne un employé ou termine les check-outs déjà ouverts.</small>
                </div>
            {% endfor %}
        </div>
    </div>

    <div id="dashboard-checkout-status-menu" class="workflow-actions-source" hidden>
        <div class="action-menu-grid">
            {% for checkout in scheduledCheckouts %}
                <div class="action-menu-tile action-menu-tile-muted action-menu-tile-checkout" data-click-url="{{ path('admin_checkout_show', {id: checkout.id}) }}">
                    <div class="action-menu-tile-top">
                        <span class="action-menu-icon action-menu-icon-blue">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm11 8H6v10h12V10ZM6 8h12V6H6v2Z" fill="currentColor"/>
                            </svg>
                        </span>
                        {% if checkout.status != constant('App\\\\Enum\\\\CheckoutStatus::InProgress') %}
                            <form
                                method="post"
                                action="{{ path('admin_checkout_cancel', {id: checkout.id}) }}"
                                data-async-form
                                data-update-target="#admin-dashboard-content"
                                data-confirm-reset
                                data-confirm-title="Annuler le check-out"
                                data-confirm-message="Veux-tu vraiment annuler ce check-out ?"
                            >
                                <input type="hidden" name="context" value="dashboard">
                                <button class="icon-action-button icon-action-button-danger" type="submit" aria-label="Annuler le check-out {{ checkout.apartment.name }}" title="Annuler le check-out">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M18.3 5.7 12 12l6.3 6.3-1.4 1.4L10.6 13.4 4.3 19.7l-1.4-1.4L9.2 12 2.9 5.7l1.4-1.4 6.3 6.3 6.3-6.3 1.4 1.4Z" fill="currentColor"/>
                                    </svg>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                    <a class="action-menu-checkout-link" href="{{ path('admin_checkout_show', {id: checkout.id}) }}">
                        <span>{{ checkout.apartment.name }}</span>
                    </a>
                    <small>
                        {{ checkout.assignedTo ? checkout.assignedTo.fullName : 'Sans employé assigné' }}
                        {% if checkout.scheduledAt %}
                            · {{ checkout.scheduledAt|date('d/m/Y H:i') }}
                        {% endif %}
                    </small>
                </div>
            {% else %}
                <div class="action-menu-tile action-menu-tile-muted">
                    <span class="action-menu-icon action-menu-icon-dark">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span>Aucun check-out en attente</span>
                    <small>Programme un check-out depuis le bloc rose.</small>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
