{% extends 'base.html.twig' %}

{% block title %}Anomalies {{ apartment.name }}{% endblock %}

{% block body %}
    {% set anomalyPanelGroup = 'apartment-anomalies-' ~ apartment.id %}

    <section class="page-head">
        <div>
            <span class="eyebrow">Anomalies appartement</span>
            <h1>{{ apartment.name }}</h1>
            <p class="muted">{{ anomalyCount }} anomalie{{ anomalyCount > 1 ? 's' : '' }} recensée{{ anomalyCount > 1 ? 's' : '' }}</p>
        </div>
        <div class="head-actions">
            <a class="secondary-button app-back-button" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">Retour appartement</a>
        </div>
    </section>

    {% if anomalyCount > 0 %}
        <section class="room-tab-nav room-tab-nav-wide">
            {% for group in anomalyGroups %}
                <a
                    href="#room-{{ group.room.id }}"
                    class="room-tab-button"
                    data-panel-open="#room-{{ group.room.id }}"
                    data-panel-group="{{ anomalyPanelGroup }}"
                    aria-controls="room-{{ group.room.id }}"
                    aria-expanded="false"
                >
                    <span>{{ group.room.name }}</span>
                    <strong class="mini-badge is-warning">{{ group.count }}</strong>
                </a>
            {% endfor %}
        </section>

        <section class="workspace-main apartment-anomalies-workspace">
            <article
                class="panel apartment-anomaly-room-placeholder"
                data-panel-name
                data-panel-group="{{ anomalyPanelGroup }}"
            >
                <div class="apartment-anomaly-room-placeholder-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M4 5h16v4H4V5Zm0 6h7v8H4v-8Zm9 0h7v8h-7v-8Z" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <h2>Sélectionnez une pièce</h2>
                    <p class="muted">Cliquez sur une pièce ci-dessus pour afficher uniquement ses anomalies et leur suivi.</p>
                </div>
            </article>

            {% for group in anomalyGroups %}
                <article
                    class="panel apartment-anomaly-room-panel is-collapsed"
                    id="room-{{ group.room.id }}"
                    data-panel-name
                    data-panel-group="{{ anomalyPanelGroup }}"
                >
                    <div class="panel-head">
                        <div>
                            <h2>{{ group.room.name }}</h2>
                            <p class="muted">{{ group.room.type.label }}</p>
                        </div>
                        <span class="status-badge is-warning">{{ group.count }} anomalie{{ group.count > 1 ? 's' : '' }}</span>
                    </div>

                    <div class="list-stack apartment-anomaly-list-stack">
                        {% for item in group.anomalies %}
                            <div id="anomaly-workflow-{{ item.anomaly.id }}">
                                {% include 'admin/_anomaly_workflow_card.html.twig' with {anomaly: item.anomaly, repeatCount: item.repeatCount} %}
                            </div>
                        {% endfor %}
                    </div>
                </article>
            {% endfor %}
        </section>
    {% else %}
        <p class="empty-state">Aucune anomalie sur cet appartement.</p>
    {% endif %}
{% endblock %}
