{% set href = href|default('https://waze.com/ul') %}
{% set title = title|default('Lancer GPS') %}
{% set className = className|default('') %}

<a href="{{ href }}" target="_blank" rel="noreferrer" class="gps-btn {{ className }}" title="{{ title }}" aria-label="{{ title }}">
    <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle class="bg" cx="60" cy="60" r="42"/>
        <circle class="pulse p1" cx="60" cy="60" r="42"/>
        <circle class="pulse p2" cx="60" cy="60" r="42"/>
        <path class="nav" d="M60 24 L78 84 L60 73 L42 84 Z"/>
    </svg>
</a>
