{% set pendingCount = room.equipmentCount - room.checkedEquipmentCount %}

<header class="airbnb-topbar">
    <a class="airbnb-icon-button" href="{{ path('admin_airbnb_check_show', {id: check.id}) }}" aria-label="Retour">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <h1>{{ room.roomName }}</h1>
    <span class="airbnb-topbar-score">{{ room.score }}%</span>
</header>

<div class="airbnb-room-progress">
    <p>{{ room.equipmentCount }} équipements à vérifier</p>
    <div class="airbnb-progress-line">
        <span style="width: {{ room.progressPercent }}%"></span>
    </div>
    <strong>{{ room.checkedEquipmentCount }} / {{ room.equipmentCount }}</strong>
</div>

{% if filter == 'all' and pendingCount > 0 %}
    <div class="airbnb-priority-note">
        <div>
            <strong>{{ pendingCount }} équipement{{ pendingCount > 1 ? 's' : '' }} à contrôler</strong>
            <span>Ils restent automatiquement en haut de la liste.</span>
        </div>
        <form
            method="post"
            action="{{ path('admin_airbnb_check_room_validate_pending', {check: check.id, room: room.id}) }}"
            class="airbnb-room-quick-validate-form"
            data-async-form
            data-update-target="#airbnb-room-content"
            data-confirm-reset
            data-confirm-title="Valider toute la pièce"
            data-confirm-message="Les {{ pendingCount }} équipement{{ pendingCount > 1 ? 's' : '' }} non contrôlé{{ pendingCount > 1 ? 's' : '' }} seront validé{{ pendingCount > 1 ? 's' : '' }} en bon état. Les équipements déjà contrôlés ne seront pas modifiés."
            data-confirm-loading-message="Validation de la pièce en cours..."
        >
            <input type="hidden" name="_token" value="{{ csrf_token('admin_airbnb_check_room_validate_pending_' ~ room.id) }}">
            <input type="hidden" name="filter" value="{{ filter }}">
            <button class="airbnb-quick-validate-button" type="submit">
                <span class="airbnb-quick-validate-icon" aria-hidden="true">
                    <svg class="airbnb-quick-validate-svg" viewBox="0 0 24 24" focusable="false">
                        <path d="M4 12.2 8.1 16.3 17.8 6.7"/>
                        <path d="M2.2 8.8 5.3 11.9 12.4 4.8"/>
                    </svg>
                </span>
                <span>
                    <strong>Valider toute la pièce</strong>
                    <em>Présent et en bon état</em>
                </span>
            </button>
        </form>
    </div>
{% endif %}

<nav class="airbnb-filter-pills" aria-label="Filtres équipements">
    <a class="{{ filter == 'all' ? 'is-active' : '' }}" href="{{ path('admin_airbnb_check_room', {check: check.id, room: room.id}) }}" data-airbnb-room-filter data-update-target="#airbnb-room-content">Tous</a>
    <a class="{{ filter == 'valid' ? 'is-active' : '' }}" href="{{ path('admin_airbnb_check_room', {check: check.id, room: room.id, filter: 'valid'}) }}" data-airbnb-room-filter data-update-target="#airbnb-room-content">Validés</a>
    <a class="{{ filter == 'missing' ? 'is-active' : '' }}" href="{{ path('admin_airbnb_check_room', {check: check.id, room: room.id, filter: 'missing'}) }}" data-airbnb-room-filter data-update-target="#airbnb-room-content">Absents</a>
    <a class="{{ filter == 'average' ? 'is-active' : '' }}" href="{{ path('admin_airbnb_check_room', {check: check.id, room: room.id, filter: 'average'}) }}" data-airbnb-room-filter data-update-target="#airbnb-room-content">État moyen</a>
</nav>

<div class="airbnb-equipment-list">
    {% for equipment in equipments %}
        {% set modalId = 'airbnb-equipment-modal-' ~ equipment.id %}
        <button
            class="airbnb-equipment-card airbnb-equipment-card-button {{ equipment.status is empty ? 'is-pending-review' : 'is-reviewed' }}"
            type="button"
            aria-haspopup="dialog"
            aria-controls="{{ modalId }}"
            data-airbnb-equipment-modal-target="#{{ modalId }}"
        >
            <span class="airbnb-equipment-icon">
                <i class="bi bi-{{ equipment.icon }}" aria-hidden="true"></i>
            </span>
            <span class="airbnb-equipment-copy">
                <strong>{{ equipment.name }}</strong>
                <em>{{ equipment.importanceLabel }}</em>
            </span>
            {% if equipment.status is empty %}
                <span class="airbnb-review-pill">À contrôler</span>
            {% endif %}
            <span class="airbnb-status-dot {{ equipment.statusClass }}">
                {% if equipment.status == 'good' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 12 4 4 8-8" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {% elseif equipment.status == 'average' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 12h10" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
                {% elseif equipment.status == 'missing' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8 8 8 8M16 8l-8 8" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
                {% elseif equipment.status == 'not_applicable' %}
                    <span>NA</span>
                {% else %}
                    <span>?</span>
                {% endif %}
            </span>
        </button>

        <div class="modal fade airbnb-equipment-modal" id="{{ modalId }}" tabindex="-1" aria-labelledby="{{ modalId }}-label" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content airbnb-equipment-modal-content">
                    <div class="modal-header">
                        <div class="airbnb-equipment-modal-title">
                            <span class="airbnb-equipment-icon">
                                <i class="bi bi-{{ equipment.icon }}" aria-hidden="true"></i>
                            </span>
                            <div>
                                <span class="airbnb-kicker">{{ equipment.importanceLabel }}</span>
                                <h4 class="modal-title" id="{{ modalId }}-label">{{ equipment.name }}</h4>
                            </div>
                        </div>
                        <button type="button" class="btn-close" aria-label="Fermer" data-bs-dismiss="modal" data-modal-close></button>
                    </div>
                    <div class="modal-body">
                        <form
                            method="post"
                            action="{{ path('admin_airbnb_check_equipment', {check: check.id, equipment: equipment.id}) }}"
                            enctype="multipart/form-data"
                            class="airbnb-equipment-form airbnb-equipment-modal-form"
                            data-async-form
                            data-update-target="#airbnb-room-content"
                            data-close-modal="{{ modalId }}"
                        >
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_airbnb_check_equipment_' ~ equipment.id) }}">
                            <input type="hidden" name="filter" value="{{ filter }}">
                            <p class="form-inline-error" data-form-error hidden></p>

                            <div class="airbnb-form-section">
                                <h3>État de l’équipement</h3>
                                <p>Sélectionne l’état actuel pour continuer rapidement.</p>

                                <div class="airbnb-status-options airbnb-status-options-compact">
                                    {% for option in statusOptions %}
                                        <label class="airbnb-status-option {{ equipment.status == option.value ? 'is-selected' : '' }}">
                                            <input type="radio" name="status" value="{{ option.value }}" {{ equipment.status == option.value ? 'checked' : '' }} required>
                                            <span class="airbnb-status-dot {{ option.value == 'good' ? 'is-good' : option.value == 'average' ? 'is-average' : option.value == 'missing' ? 'is-missing' : 'is-na' }}">
                                                <i class="bi bi-{{ option.icon }}" aria-hidden="true"></i>
                                            </span>
                                            <span>
                                                <strong>{{ option.label }}</strong>
                                                <em>{{ option.description }}</em>
                                            </span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>

                            <div class="airbnb-form-section airbnb-form-section-soft">
                                <label>
                                    <span>Note interne</span>
                                    <textarea name="note" rows="2" placeholder="Ex. rayures visibles, remplacement conseillé...">{{ equipment.note }}</textarea>
                                </label>
                                <label>
                                    <span>Tâche à créer</span>
                                    <input type="text" name="taskLabel" value="{{ equipment.taskLabel }}" placeholder="Ex. Ajouter un sèche-cheveux">
                                </label>
                                <label>
                                    <span>Photo</span>
                                    <input type="file" name="photo" accept="image/*">
                                </label>
                                {% if equipment.photoPath %}
                                    <img class="airbnb-equipment-photo" src="{{ asset(equipment.photoPath) }}" alt="Photo {{ equipment.name }}">
                                {% endif %}
                            </div>

                            <div class="airbnb-modal-actions">
                                <button class="airbnb-primary-button" type="submit">Valider cet équipement</button>
                                <button class="airbnb-secondary-button" type="button" data-bs-dismiss="modal" data-modal-close>Annuler</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="airbnb-empty-state">
            <strong>Aucun équipement dans ce filtre.</strong>
            <p>Change de filtre pour retrouver les équipements de la pièce.</p>
        </div>
    {% endfor %}
</div>
