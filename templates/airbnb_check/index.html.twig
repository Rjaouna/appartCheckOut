{% extends 'base.html.twig' %}

{% block title %}Check d’utilisabilité Airbnb{% endblock %}
{% block body_class %}airbnb-check-body{% endblock %}

{% block body %}
    <section class="airbnb-shell airbnb-module-home">
        <div class="airbnb-mobile-frame">
            <header class="airbnb-topbar">
                <a class="airbnb-icon-button" href="{{ path('admin_dashboard') }}" aria-label="Retour">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a class="airbnb-pill-link" href="{{ path('admin_airbnb_check_reports') }}">Voir les rapports</a>
            </header>

            <div class="airbnb-center-title">
                <h1>Check d’utilisabilité Airbnb</h1>
            </div>

            <div class="airbnb-score-card airbnb-score-card-wide">
                <div>
                    <span>Rapports enregistrés</span>
                    <strong>{{ reportCount }}</strong>
                </div>
                <div class="airbnb-orbit" aria-hidden="true"></div>
            </div>

            <div class="airbnb-section-head">
                <div>
                    <h2>Logements</h2>
                </div>
            </div>

            <div class="airbnb-apartment-list">
                {% for apartment in apartments %}
                    {% set latestCheck = latestChecks[apartment.id] ?? null %}
                    <article class="airbnb-apartment-card">
                        <div class="airbnb-apartment-card-main">
                            <div class="airbnb-room-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.6 12 3l9 7.6V21h-6v-6H9v6H3V10.6Z" fill="currentColor"/></svg>
                            </div>
                            <div>
                                <h3>{{ apartment.name }}</h3>
                                <p>{{ apartment.city }} · {{ apartment.ownerName ?: 'Propriétaire non renseigné' }}</p>
                                {% if latestCheck %}
                                    <span class="airbnb-audit-badge {{ latestCheck.badgeClass }}">{{ latestCheck.badgeLabel }}</span>
                                {% else %}
                                    <span class="airbnb-audit-badge is-neutral">Non audité</span>
                                {% endif %}
                            </div>
                        </div>
                        <form method="post" action="{{ path('admin_airbnb_check_launch', {id: apartment.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_airbnb_check_launch_' ~ apartment.id) }}">
                            <button class="airbnb-primary-button" type="submit">Lancer le check</button>
                        </form>
                    </article>
                {% else %}
                    <div class="airbnb-empty-state">
                        <strong>Aucun appartement actif.</strong>
                        <p>Ajoute d’abord un logement actif pour lancer un audit Airbnb.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
