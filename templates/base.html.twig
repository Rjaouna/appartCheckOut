<!DOCTYPE html>
<html lang="fr" class="app-shell-pending">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="theme-color" content="#ff385c">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="apple-mobile-web-app-title" content="Check-out">
        <title>{% block title %}Gestion Check-out{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 64 64%22><path fill=%22%23ff385c%22 d=%22M32 8c-3.8 0-6.6 1.9-8.3 5.7L13 38.2c-1.4 3.1-1.2 6 .6 8.6 1.8 2.6 4.4 3.9 7.8 3.9h21.2c3.4 0 6-1.3 7.8-3.9 1.8-2.6 2-5.5.6-8.6L40.3 13.7C38.6 9.9 35.8 8 32 8Zm0 7.3c1.1 0 1.9.6 2.5 1.9l10.8 24.7c.6 1.3.5 2.4-.2 3.4-.7 1-1.7 1.5-3 1.5H21.9c-1.3 0-2.3-.5-3-1.5-.7-1-.8-2.1-.2-3.4l10.8-24.7c.6-1.3 1.4-1.9 2.5-1.9Z%22/></svg>">
        <link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
        <link rel="apple-touch-icon" href="{{ asset('icons/apple-touch-icon.png') }}">
        <style>
            html.app-shell-pending .top-app-bar,
            html.app-shell-pending .shell-header,
            html.app-shell-pending .floating-main-menu-button {
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
            }
        </style>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <script>
            window.addEventListener('load', function () {
                document.documentElement.classList.remove('app-shell-pending');
            });
        </script>
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% if app.user %}
            <div class="top-app-bar">
                <a class="top-app-brand" href="{{ is_granted('ROLE_ADMIN') ? path('admin_dashboard') : path('employee_dashboard') }}">
                    <span class="top-app-brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 64 64">
                            <path fill="currentColor" d="M32 8c-3.8 0-6.6 1.9-8.3 5.7L13 38.2c-1.4 3.1-1.2 6 .6 8.6 1.8 2.6 4.4 3.9 7.8 3.9h21.2c3.4 0 6-1.3 7.8-3.9 1.8-2.6 2-5.5.6-8.6L40.3 13.7C38.6 9.9 35.8 8 32 8Zm0 7.3c1.1 0 1.9.6 2.5 1.9l10.8 24.7c.6 1.3.5 2.4-.2 3.4-.7 1-1.7 1.5-3 1.5H21.9c-1.3 0-2.3-.5-3-1.5-.7-1-.8-2.1-.2-3.4l10.8-24.7c.6-1.3 1.4-1.9 2.5-1.9Z"/>
                        </svg>
                    </span>
                    <span class="top-app-brand-text">Check-out</span>
                </a>

                <div class="top-app-actions">
                    <button
                        class="top-app-install-button"
                        type="button"
                        title="Installer l’application"
                        aria-label="Installer l’application"
                        data-install-app-trigger
                        hidden
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 4v9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <path d="M8.5 10.5 12 14l3.5-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M5 17v1a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3v-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                    </button>

                    <button
                        id="floating-main-menu-button"
                        class="floating-main-menu-button"
                        type="button"
                        title="Ouvrir le menu"
                        aria-label="Ouvrir le menu principal"
                        data-action-menu-trigger
                        data-action-menu-title="Menu principal"
                        data-action-menu-source="#global-main-menu"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h16v2H4v-2Z" fill="currentColor"/>
                        </svg>
                    </button>
                </div>
            </div>
        {% endif %}

        <main class="page-shell">
            {% block body %}{% endblock %}
        </main>

        <button
            id="scroll-to-top-button"
            class="scroll-to-top-button"
            type="button"
            aria-label="Remonter en haut"
            title="Remonter en haut"
        >
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5 5 12l1.4 1.4L11 8.8V20h2V8.8l4.6 4.6L19 12l-7-7Z" fill="currentColor"/>
            </svg>
        </button>

        <div id="toast-stack" class="app-toast-stack" aria-live="polite">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="app-toast {{ label in ['error', 'danger'] ? 'app-toast-error' : '' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
        </div>

        {% if app.user %}
            <div id="global-main-menu" class="workflow-actions-source" hidden>
                <div class="action-menu-layout">
                    <div class="action-menu-grid">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="action-menu-tile" href="{{ path('admin_dashboard') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h7V4H4v9Zm0 7h7v-5H4v5Zm9 0h7v-9h-7v9Zm0-16v5h7V4h-7Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Dashboard</span>
                                <span class="action-menu-tile-caption">Vue d’ensemble et pilotage rapide</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('admin_apartments') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3v-10.5Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Appartements</span>
                                <span class="action-menu-tile-caption">Liste, fiches et accès logements</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('admin_anomalies') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 1 21h22L12 2Zm1 14h-2v-2h2v2Zm0-4h-2V8h2v4Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Anomalies</span>
                                <span class="action-menu-tile-caption">Suivi des problèmes à traiter</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('admin_users') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4ZM8 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm8 2c-2.67 0-8 1.34-8 4v3h16v-3c0-2.66-5.33-4-8-4ZM8 13c-.29 0-.62.02-.97.05C4.42 13.27 0 14.44 0 17v3h6v-3c0-1.16.55-2.18 1.53-3A8.63 8.63 0 0 1 8 13Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Employés</span>
                                <span class="action-menu-tile-caption">Profils, équipe et services</span>
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_EMPLOYEE') and not is_granted('ROLE_ADMIN') %}
                            <a class="action-menu-tile" href="{{ path('employee_dashboard') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3v-10.5Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Mon espace</span>
                                <span class="action-menu-tile-caption">Accueil et vue rapide du jour</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('employee_calendar') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm11 8H6v10h12V10ZM6 8h12V6H6v2Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Calendrier</span>
                                <span class="action-menu-tile-caption">Check-outs programmés et à venir</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('employee_history') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 3a9 9 0 1 0 8.95 10H19.9A7 7 0 1 1 13 5v3l5-4-5-4v3Zm-1 5h2v6h-5v-2h3V8Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Historique</span>
                                <span class="action-menu-tile-caption">Passages déjà terminés</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('employee_anomalies') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 1 21h22L12 2Zm1 14h-2v-2h2v2Zm0-4h-2V8h2v4Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Mes anomalies</span>
                                <span class="action-menu-tile-caption">Déclarations et suivi terrain</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('employee_apartments') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 21V7l9-4 9 4v14H3Zm5-2h2v-2H8v2Zm0-4h2v-2H8v2Zm0-4h2V9H8v2Zm6 8h2v-2h-2v2Zm0-4h2v-2h-2v2Zm0-4h2V9h-2v2Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Appartements</span>
                                <span class="action-menu-tile-caption">Codes, Waze et détails utiles</span>
                            </a>
                            <a class="action-menu-tile" href="{{ path('employee_profile') }}">
                                <span class="action-menu-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4 0-7 2-7 4.5V21h14v-2.5C19 16 16 14 12 14Z" fill="currentColor"/></svg>
                                </span>
                                <span class="action-menu-tile-label">Profil</span>
                                <span class="action-menu-tile-caption">Informations et services activés</span>
                            </a>
                        {% endif %}
                        <button
                            class="action-menu-tile action-menu-tile-button"
                            type="button"
                            data-install-app-trigger
                            hidden
                        >
                            <span class="action-menu-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 3v10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                    <path d="M8.5 9.5 12 13l3.5-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M5 15v2a4 4 0 0 0 4 4h6a4 4 0 0 0 4-4v-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                            </span>
                            <span class="action-menu-tile-label">Installer l’application</span>
                            <span class="action-menu-tile-caption">Accès rapide depuis l’écran d’accueil</span>
                        </button>
                        <a class="action-menu-tile action-menu-tile-danger" href="{{ path('app_logout') }}">
                            <span class="action-menu-icon action-menu-icon-danger">
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 17v-2h4V9h-4V7h6v10h-6Zm-7 4V3h9v2H5v14h7v2H3Zm13.6-6-1.4-1.4 1.6-1.6H9v-2h7.8l-1.6-1.6L16.6 7l4 4-4 4Z" fill="currentColor"/></svg>
                            </span>
                            <span class="action-menu-tile-label">Déconnexion</span>
                            <span class="action-menu-tile-caption">Fermer la session en cours</span>
                        </a>
                    </div>

                    <div class="action-menu-shortcuts-panel">
                        <div class="action-menu-shortcuts-copy">
                            <span class="action-menu-section-title">Raccourcis</span>
                            {% if is_granted('ROLE_ADMIN') %}
                                <p>Accède rapidement aux actions les plus fréquentes.</p>
                            {% else %}
                                <p>Retrouve les accès utiles sans repasser par l’accueil.</p>
                            {% endif %}
                        </div>

                        <div class="action-menu-shortcuts">
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_apartments') }}">Ajouter un appartement</a>
                                <a href="{{ path('admin_users') }}">Gérer l’équipe</a>
                                <a href="{{ path('admin_anomalies') }}">Suivre les anomalies</a>
                                <a href="{{ path('admin_dashboard') }}">Voir les check-outs</a>
                            {% else %}
                                <a href="{{ path('employee_calendar') }}">Voir mon calendrier</a>
                                <a href="{{ path('employee_apartments') }}">Ouvrir mes appartements</a>
                                <a href="{{ path('employee_anomalies') }}">Suivre mes anomalies</a>
                                <a href="{{ path('employee_profile') }}">Gérer mon profil</a>
                            {% endif %}
                        </div>

                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="action-menu-note-card">
                                <div class="action-menu-note-head">
                                    <strong>Validation des services</strong>
                                    {% if pendingServiceOffers is defined and pendingServiceOffers|length > 0 %}
                                        <span class="action-menu-note-badge">{{ pendingServiceOffers|length }}</span>
                                    {% endif %}
                                </div>
                                {% if pendingServiceOffers is defined and pendingServiceOffers|length > 0 %}
                                    <p>{{ pendingServiceOffers|length }} service{{ pendingServiceOffers|length > 1 ? 's' : '' }} à relire et à valider.</p>
                                    <a href="{{ path('admin_users') }}">Ouvrir les profils employés</a>
                                {% else %}
                                    <p>Les propositions de services des employés se valident depuis les fiches employés.</p>
                                    <a href="{{ path('admin_users') }}">Aller à l’équipe</a>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="modal fade" id="confirmActionModal" tabindex="-1" aria-labelledby="confirmActionModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="confirmActionModalLabel">Confirmer l'action</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body" id="confirmActionModalBody">
                        Veux-tu vraiment continuer ?
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
                        <button type="button" class="btn btn-danger" id="confirmActionModalSubmit">Confirmer</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="workflowActionModal" tabindex="-1" aria-labelledby="workflowActionModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="workflowActionModalLabel">Suivi du dossier</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <div id="workflowActionModalContent"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="actionMenuModal" tabindex="-1" aria-labelledby="actionMenuModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-fullscreen">
                <div class="modal-content action-menu-modal-content">
                    <div class="modal-header action-menu-modal-header">
                        <h4 class="modal-title" id="actionMenuModalLabel">Actions appartement</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body action-menu-modal-body">
                        <div id="actionMenuModalContent"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-labelledby="photoLightboxModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content lightbox-modal-content">
                    <div class="modal-header lightbox-modal-header">
                        <h5 class="modal-title" id="photoLightboxModalLabel">Photo</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body lightbox-modal-body">
                        <img id="photoLightboxImage" class="lightbox-image" src="" alt="">
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="installHelpModal" tabindex="-1" aria-labelledby="installHelpModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="installHelpModalLabel">Installer l’application</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <p>Sur iPhone avec Safari, l’installation se fait en quelques secondes :</p>
                        <ol class="install-help-list">
                            <li>Appuie sur le bouton <strong>Partager</strong> de Safari.</li>
                            <li>Choisis <strong>Sur l’écran d’accueil</strong>.</li>
                            <li>Valide avec <strong>Ajouter</strong>.</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
