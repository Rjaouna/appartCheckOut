{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle|default('Historique des check-ins') }}{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <span class="eyebrow">{{ pageEyebrow|default('Administration') }}</span>
            <h1>{{ pageTitle|default('Historique des check-ins') }}</h1>
            <p>{{ checkins|length }} {{ checkins|length > 1 ? pageDescriptionPlural|default('fiches enregistrées pour la transmission papier.') : pageDescription|default('fiche enregistrée pour la transmission papier.') }}</p>
        </div>
        <div class="head-actions">
            <a class="secondary-button" href="{{ path(activeListRoute|default('admin_checkins')) }}">{{ activeListLabel|default('Check-ins en cours') }}</a>
            <a class="secondary-button app-back-button" href="{{ path(backRoute|default('admin_dashboard')) }}">Retour</a>
        </div>
    </section>

    <div class="room-stack checkin-card-stack">
        {% for checkin in checkins %}
            {% set reservation = checkin.reservation %}
            {% set apartment = reservation ? reservation.apartment : null %}
            {% set guestName = reservation ? reservation.guestName : checkin.guestName %}
            {% set apartmentName = apartment ? apartment.name : checkin.apartmentName %}
            <article class="room-card checkin-card {{ checkin.processed ? 'is-treated' : 'is-history-pending' }}">
                <div class="room-card-head checkin-card-head">
                    <div>
                        <h3>{{ guestName }}</h3>
                        <p>
                            {% if apartment %}
                                <a class="entity-shortcut-link" href="{{ path('admin_apartment_show', {id: apartment.id}) }}">{{ apartmentName }}</a>
                            {% else %}
                                <strong>{{ apartmentName }}</strong>
                            {% endif %}
                            · Fiche du {{ checkin.completedAt|date('d/m/Y H:i') }}
                        </p>
                    </div>
                    <span class="status-badge {{ checkin.processed ? 'is-success' : 'is-warning' }}">
                        {{ checkin.processed ? 'Traité' : 'Non traité' }}
                    </span>
                </div>

                <div class="checkin-card-grid">
                    <div class="checkin-mini-fact">
                        <span>Voyageurs</span>
                        <strong>{{ checkin.guestCount }}</strong>
                    </div>
                    <div class="checkin-mini-fact">
                        <span>Dates</span>
                        <strong>{{ checkin.checkInDate|date('d/m/Y') }} → {{ checkin.checkOutDate|date('d/m/Y') }}</strong>
                    </div>
                    <div class="checkin-mini-fact">
                        <span>Agent</span>
                        {% if checkin.completedBy %}
                            <a href="{{ path('admin_user_show', {id: checkin.completedBy.id}) }}">{{ checkin.hostAgentName }}</a>
                        {% else %}
                            <strong>{{ checkin.hostAgentName }}</strong>
                        {% endif %}
                    </div>
                </div>

                <div class="checkin-card-actions">
                    <a class="primary-button" href="{{ path('admin_checkin_show', {id: checkin.id}) }}">Voir la fiche</a>
                    {% if not checkin.processed %}
                        <form method="post" action="{{ path('admin_checkin_mark_processed', {id: checkin.id}) }}">
                            <button class="secondary-button" type="submit">Marquer traité</button>
                        </form>
                    {% endif %}
                    {% if allowReservationDelete|default(false) %}
                        <form
                            method="post"
                            action="{{ path('admin_arrival_history_delete', {id: checkin.id}) }}"
                            class="checkin-history-delete-form"
                            data-confirm-reset
                            data-confirm-title="Supprimer cette arrivée"
                            data-confirm-message="Cette fiche check-in et la réservation liée seront supprimées. Les dates seront libérées pour refaire un test. Continuer ?"
                        >
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_arrival_history_' ~ checkin.id) }}">
                            <button class="icon-action-button icon-action-button-danger" type="submit" aria-label="Supprimer cette arrivée" title="Supprimer et libérer les dates">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M9 4h6l1 2h4v2H4V6h4l1-2Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                    <path d="M7 9h10l-.7 10.2A2 2 0 0 1 14.3 21H9.7a2 2 0 0 1-2-1.8L7 9Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                                    <path d="M10 12v5M14 12v5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </button>
                        </form>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <p class="empty-state">Aucune fiche check-in enregistrée pour le moment.</p>
        {% endfor %}
    </div>
{% endblock %}
